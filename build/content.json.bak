    "603": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "살다; 거주하다; (~ on) 곱씹다, 깊이 생각하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Many wild animals dwell in the deep forest.",
          "ko": "많은 야생 동물이 깊은 숲속에 산다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "People who dwell in big cities often long for the quiet of the countryside.",
          "ko": "대도시에 사는 사람들은 종종 시골의 고요함을 그리워한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 2,
          "en": "You should not dwell on past mistakes if you want to make real progress.",
          "ko": "진정한 발전을 원한다면 과거의 실수를 곱씹어서는 안 된다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Psychologists warn that those who continually dwell on negative memories may find it difficult to cultivate a resilient and hopeful outlook.",
          "ko": "심리학자들은 부정적인 기억을 끊임없이 곱씹는 사람들은 회복력 있고 희망적인 태도를 기르기 어려울 수 있다고 경고한다.",
          "sort_order": 3
        }
      ]
    },
    "1052": {
      "meanings": [
