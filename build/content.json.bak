      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "This house is my father's property.",
          "ko": "이 집은 우리 아버지의 재산이다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The company bought a large piece of property where it plans to build a new factory.",
          "ko": "그 회사는 새 공장을 지을 계획인 넓은 부동산을 사들였다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Disputes over private property often reveal deep tensions between individual rights and the collective interests of a community.",
          "ko": "사유 재산을 둘러싼 분쟁은 흔히 개인의 권리와 공동체의 집단적 이익 사이의 깊은 긴장을 드러낸다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "Water has the property of taking any shape.",
          "ko": "물은 어떤 형태든 취하는 특성을 지닌다.",
          "sort_order": 3
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Scientists study the physical properties of metals to decide how they can be used.",
          "ko": "과학자들은 금속을 어떻게 사용할 수 있는지 결정하기 위해 그 물리적 특성을 연구한다.",
          "sort_order": 4
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Understanding the chemical properties of a substance allows researchers to predict how it will react under various environmental conditions.",
          "ko": "어떤 물질의 화학적 특성을 이해하면 연구자들은 그것이 다양한 환경 조건에서 어떻게 반응할지 예측할 수 있다.",
          "sort_order": 5
        }
      ]
    },
