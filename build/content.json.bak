          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "We discovered a small cave near the river.",
          "ko": "우리는 강 근처에서 작은 동굴을 발견했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "She was surprised to discover that her old friend lived in the same town.",
          "ko": "그녀는 옛 친구가 같은 마을에 산다는 것을 알아내고 놀랐다.",
