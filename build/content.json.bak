        {
          "pos": "n",
          "level": 2,
          "en": "Turn left at the corner, and you will find the library next to the park.",
          "ko": "모퉁이에서 왼쪽으로 돌면 공원 옆에 도서관이 보일 것이다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "In every corner of modern society, digital technology quietly shapes how people communicate, work, and even form their opinions.",
          "ko": "현대 사회의 모든 구석에서 디지털 기술은 사람들이 소통하고, 일하고, 심지어 의견을 형성하는 방식을 조용히 형성한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The dog tried to corner the small mouse.",
          "ko": "그 개는 작은 쥐를 구석으로 몰려고 했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The reporter cornered the official with questions that he could not easily avoid.",
          "ko": "기자는 그 관리를 쉽게 피할 수 없는 질문들로 궁지에 몰았다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "A single company that manages to corner the market for a scarce resource can influence prices far beyond its own borders.",
          "ko": "희소한 자원의 시장을 독점하는 데 성공한 한 회사는 자국의 경계를 훨씬 넘어 가격에 영향을 미칠 수 있다.",
          "sort_order": 2
        }
      ]
    },
    "705": {
      "meanings": [
