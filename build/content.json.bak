        {
          "pos": "n",
          "level": 3,
          "en": "Historians studied the ancient seal carefully, for its intricate symbols could reveal the political authority of a long-forgotten kingdom.",
          "ko": "역사가들은 그 고대 봉인을 주의 깊게 연구했는데, 정교한 상징들이 오래 잊힌 왕국의 정치적 권위를 드러낼 수 있었기 때문이다.",
          "sort_order": 5
        }
      ]
    },
    "1492": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "애완동물; 반려동물",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "쓰다듬다; 어루만지다",
          "sort_order": 1
        },
        {
          "pos": "a",
          "meaning_ko": "애완용의; 특히 좋아하는",
          "sort_order": 2
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My little sister wants a pet dog for her birthday.",
          "ko": "내 여동생은 생일 선물로 애완견을 원한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Many families adopt a pet from a shelter, hoping to give the animal a better life.",
          "ko": "많은 가정이 그 동물에게 더 나은 삶을 주기를 바라며 보호소에서 반려동물을 입양한다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Recent studies suggest that keeping a pet can reduce stress and loneliness among elderly people living alone.",
          "ko": "최근 연구들은 반려동물을 기르는 것이 홀로 사는 노인들의 스트레스와 외로움을 줄일 수 있음을 시사한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The child gently petted the soft rabbit.",
          "ko": "그 아이는 부드러운 토끼를 살며시 쓰다듬었다.",
          "sort_order": 3
        },
        {
          "pos": "v",
          "level": 2,
          "en": "When the nervous dog approached, she knelt down and petted it until it calmed down.",
          "ko": "불안해하는 개가 다가오자 그녀는 무릎을 꿇고 그 개가 진정될 때까지 쓰다듬어 주었다.",
          "sort_order": 4
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Volunteers who regularly pet the rescued animals help them regain trust in humans after months of neglect.",
          "ko": "구조된 동물들을 정기적으로 쓰다듬어 주는 자원봉사자들은 수개월간의 방치 후 그 동물들이 인간에 대한 신뢰를 되찾도록 돕는다.",
          "sort_order": 5
        },
        {
          "pos": "a",
          "level": 1,
          "en": "Reading is her pet hobby on weekends.",
          "ko": "독서는 주말에 그녀가 특히 좋아하는 취미이다.",
          "sort_order": 6
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The teacher always returns to her pet topic whenever the class discussion slows down.",
          "ko": "그 선생님은 수업 토론이 느슨해질 때마다 늘 자신이 특히 좋아하는 주제로 돌아간다.",
          "sort_order": 7
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Environmental protection has become his pet subject, one he passionately defends in nearly every academic debate he joins.",
          "ko": "환경 보호는 그가 특히 애착을 갖는 주제가 되었으며, 그가 참여하는 거의 모든 학술 토론에서 열정적으로 옹호하는 주제이다.",
          "sort_order": 8
        }
      ]
    },
    "36": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "전진하다; 발전하다; 진척시키다",
          "sort_order": 0
        },
