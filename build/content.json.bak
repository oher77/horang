      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We heard a loud blast from the old building.",
          "ko": "우리는 낡은 건물에서 나는 큰 폭발 소리를 들었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "A cold blast of wind swept across the field while we were waiting outside.",
          "ko": "우리가 밖에서 기다리는 동안 차가운 돌풍이 들판을 가로질러 불어왔다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The sudden blast of the explosion, which shattered nearby windows, reminded residents how fragile their sense of safety truly was.",
          "ko": "근처 창문을 산산조각 낸 갑작스러운 폭발음은 주민들에게 그들의 안전감이 얼마나 취약한지를 일깨워 주었다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Workers will blast the rock to build the road.",
          "ko": "인부들은 도로를 만들기 위해 바위를 폭파할 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The radio began to blast music so loudly that we could not hear each other.",
          "ko": "라디오가 음악을 너무 크게 울려대서 우리는 서로의 말을 들을 수 없었다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Engineers had to blast through the mountainside carefully, ensuring that the vibrations would not weaken the ancient structures standing nearby.",
          "ko": "기술자들은 진동이 근처에 서 있는 고대 건축물을 약화시키지 않도록 하면서 산비탈을 조심스럽게 폭파해야 했다.",
          "sort_order": 2
        }
      ]
    },
