        },
        {
          "pos": "v",
          "level": 3,
          "en": "Reputable journalists strive to cover controversial events fairly, presenting multiple perspectives without distorting the underlying facts.",
          "ko": "신뢰할 만한 기자들은 논란이 되는 사건을 공정하게 보도하려 애쓰며, 근본적인 사실을 왜곡하지 않고 여러 관점을 제시한다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "Please put the cover back on the box.",
          "ko": "상자에 덮개를 다시 씌워 주세요.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The magazine's cover featured a photo that quickly caught readers' attention.",
          "ko": "그 잡지의 표지에는 독자들의 관심을 금세 사로잡은 사진이 실렸다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The insurance policy provides comprehensive cover against damages that might otherwise devastate a small family business.",
          "ko": "그 보험 증권은 그렇지 않으면 소규모 가족 사업을 파탄시킬 수 있는 손해에 대해 포괄적인 보장을 제공한다.",
          "sort_order": 2
        }
      ]
