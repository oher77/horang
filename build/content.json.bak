          "sort_order": 2
        }
      ]
    },
    "2158": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "복지; 후생; 행복",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The school cares about the welfare of every student.",
          "ko": "학교는 모든 학생의 복지에 관심을 기울인다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The city built new parks to improve the welfare of local families.",
          "ko": "그 도시는 지역 가정의 복지를 향상시키기 위해 새로운 공원을 지었다.",
