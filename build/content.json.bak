      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Please put on your coat before you go out.",
          "ko": "밖에 나가기 전에 외투를 입으세요.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "She bought a warm coat because the winter mornings were getting colder every day.",
          "ko": "겨울 아침이 날마다 더 추워져서 그녀는 따뜻한 외투를 샀다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The animal's thick coat serves as insulation, allowing it to survive in environments where temperatures drop far below freezing.",
          "ko": "그 동물의 두꺼운 털은 단열재 역할을 하여, 기온이 영하로 크게 떨어지는 환경에서도 생존할 수 있게 한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "They coat the cake with sweet chocolate.",
          "ko": "그들은 케이크에 달콤한 초콜릿을 입힌다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The workers coat the metal with paint so that it does not rust over time.",
          "ko": "작업자들은 시간이 지나도 녹슬지 않도록 금속에 페인트를 칠한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Manufacturers often coat lenses with a thin chemical film that reduces glare and protects the surface from scratches.",
          "ko": "제조업체들은 눈부심을 줄이고 표면을 긁힘으로부터 보호하기 위해 렌즈에 얇은 화학 막을 입히는 경우가 많다.",
          "sort_order": 2
        }
      ]
    },
    "2279": {
      "meanings": [
