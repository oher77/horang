    "346": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "축하하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I want to congratulate you on your new job.",
          "ko": "네 새 직장을 축하하고 싶어.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher stopped to congratulate the students who had won the science contest.",
          "ko": "선생님은 과학 대회에서 우승한 학생들을 축하하려고 멈춰 섰다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Rather than simply congratulate winners, wise mentors also acknowledge the effort of those who quietly persevered without recognition.",
          "ko": "현명한 멘토들은 단순히 우승자를 축하하기보다, 인정받지 못한 채 묵묵히 인내한 이들의 노력도 알아준다.",
          "sort_order": 2
        }
      ]
    },
    "1771": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "경쟁자; 라이벌; 적수",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "필적하다; 겨루다",
          "sort_order": 1
        },
        {
          "pos": "a",
          "meaning_ko": "경쟁하는; 대립하는",
          "sort_order": 2
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "He is my main rival in the swimming race.",
          "ko": "그는 수영 경기에서 나의 주요 경쟁자다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The two companies became fierce rivals when they entered the same market last year.",
          "ko": "두 회사는 작년에 같은 시장에 진입하면서 치열한 경쟁자가 되었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Historians note that long-standing rivals often push each other toward greater achievements through constant competition.",
          "ko": "역사가들은 오랜 경쟁자들이 끊임없는 경쟁을 통해 서로를 더 큰 성취로 밀어붙이는 경우가 많다고 지적한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Few singers can rival her beautiful voice.",
          "ko": "그녀의 아름다운 목소리에 필적할 수 있는 가수는 거의 없다.",
          "sort_order": 3
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The new smartphone rivals the best cameras that professionals use for their work.",
          "ko": "그 새 스마트폰은 전문가들이 작업에 사용하는 최고급 카메라에 필적한다.",
          "sort_order": 4
        },
        {
          "pos": "v",
          "level": 3,
          "en": "The economic growth of the small nation now rivals that of countries with far larger populations and resources.",
          "ko": "그 작은 나라의 경제 성장은 이제 훨씬 더 많은 인구와 자원을 가진 나라들의 성장에 필적한다.",
          "sort_order": 5
        },
        {
          "pos": "a",
          "level": 1,
          "en": "Fans from the rival team filled the other side.",
          "ko": "상대 팀의 팬들이 반대편을 가득 메웠다.",
          "sort_order": 6
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Students from rival schools competed in the debate contest held downtown.",
          "ko": "경쟁 학교의 학생들이 시내에서 열린 토론 대회에서 겨루었다.",
          "sort_order": 7
        },
        {
          "pos": "a",
          "level": 3,
          "en": "The dispute arose because two rival groups of scientists proposed conflicting theories to explain the same natural phenomenon.",
          "ko": "그 논쟁은 서로 경쟁하는 두 과학자 집단이 같은 자연 현상을 설명하기 위해 상반된 이론을 제시하면서 발생했다.",
          "sort_order": 8
        }
      ]
    },
    "1979": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "자극하다; 촉진하다; 활성화하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Warm milk can help stimulate sleep at night.",
