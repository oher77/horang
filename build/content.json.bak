      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "He likes to cite famous lines from old movies.",
          "ko": "그는 오래된 영화의 유명한 대사를 인용하기를 좋아한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher asked us to cite reliable sources when we write our essays.",
          "ko": "선생님은 우리가 에세이를 쓸 때 신뢰할 수 있는 출처를 인용하라고 하셨다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Scholars who cite earlier studies carefully allow readers to trace how a particular idea has evolved across decades of research.",
          "ko": "이전 연구들을 신중히 인용하는 학자들은 특정 개념이 수십 년의 연구에 걸쳐 어떻게 발전해 왔는지를 독자들이 추적할 수 있게 해 준다.",
          "sort_order": 2
        }
      ]
    },
    "814": {
      "meanings": [
        {
