      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "The sky was clear and blue all day.",
          "ko": "하늘은 하루 종일 맑고 파랬다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The teacher gave clear instructions so that no student would feel confused.",
          "ko": "선생님은 어떤 학생도 혼란스럽지 않도록 분명한 지시를 해 주셨다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "It became clear that the sudden decline in sales resulted from a fundamental shift in consumer behavior.",
          "ko": "매출의 갑작스러운 감소가 소비자 행동의 근본적 변화에서 비롯되었다는 것이 분명해졌다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Please clear the table after dinner.",
          "ko": "저녁 식사 후에는 식탁을 치워 주세요.",
          "sort_order": 3
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Workers spent the morning clearing the snow that had blocked the school gate.",
          "ko": "인부들은 학교 정문을 막고 있던 눈을 치우며 아침을 보냈다.",
          "sort_order": 4
        },
        {
          "pos": "v",
          "level": 3,
          "en": "New evidence finally cleared the suspect, whose reputation had been unfairly damaged for years.",
          "ko": "새로운 증거가 마침내 그 용의자의 혐의를 벗겨 주었는데, 그의 명예는 수년간 부당하게 훼손되어 왔다.",
          "sort_order": 5
        },
        {
          "pos": "ad",
          "level": 1,
          "en": "Stand clear of the closing doors.",
          "ko": "닫히는 문에서 떨어져 서 주세요.",
          "sort_order": 6
        },
        {
          "pos": "ad",
          "level": 2,
          "en": "The runner leaped clear of the hurdle and kept her lead until the finish line.",
          "ko": "그 주자는 장애물을 완전히 뛰어넘어 결승선까지 선두를 지켰다.",
          "sort_order": 7
        },
        {
          "pos": "ad",
          "level": 3,
          "en": "Engineers designed the barrier to keep pedestrians clear of the tracks, thereby reducing accidents at busy crossings.",
          "ko": "기술자들은 보행자를 선로에서 완전히 떨어져 있게 하려고 그 차단벽을 설계했고, 그로써 붐비는 건널목에서의 사고를 줄였다.",
          "sort_order": 8
        }
      ]
    },
    "356": {
