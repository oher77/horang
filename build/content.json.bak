    "834": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "얼다; 얼리다; 얼어붙다; 동결하다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "동결; 결빙; (임금·물가의) 동결",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The water in the lake will freeze in winter.",
          "ko": "겨울에는 호수의 물이 얼 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "You should freeze the leftover soup so that it does not go bad.",
          "ko": "남은 수프가 상하지 않도록 얼려 두는 것이 좋다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When people freeze in a moment of danger, their bodies often prioritize immediate survival over careful reasoning.",
          "ko": "사람들이 위험한 순간에 얼어붙을 때, 그들의 몸은 흔히 신중한 추론보다 즉각적인 생존을 우선시한다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "There was a sudden freeze last night.",
          "ko": "어젯밤에 갑작스러운 결빙이 있었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The company announced a freeze on wages, which upset many of its workers.",
          "ko": "회사가 임금 동결을 발표했고, 이는 많은 직원들을 화나게 했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The government imposed a temporary freeze on new construction while officials assessed the long-term impact on the environment.",
          "ko": "당국이 환경에 미치는 장기적 영향을 평가하는 동안 정부는 신규 건설에 대한 일시적 동결을 시행했다.",
          "sort_order": 2
        }
      ]
    },
