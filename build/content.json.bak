          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher asked us to fill the blanks with the words that we had just learned.",
          "ko": "선생님은 우리가 방금 배운 단어들로 빈칸을 채우라고 하셨다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "A sudden sense of relief filled the room as the committee announced that the long-delayed project would finally proceed.",
          "ko": "오랫동안 미뤄졌던 그 프로젝트가 마침내 진행된다고 위원회가 발표하자 갑작스러운 안도감이 방을 가득 채웠다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "He ate his fill and left the table.",
          "ko": "그는 배불리 먹고 식탁을 떠났다.",
          "sort_order": 3
        },
        {
          "pos": "n",
          "level": 2,
          "en": "After the long hike, the travelers drank their fill of water before resting under the trees.",
          "ko": "긴 하이킹 후에 여행자들은 나무 아래서 쉬기 전에 물을 실컷 마셨다.",
          "sort_order": 4
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Having had their fill of endless debate, the delegates finally sought a compromise that both sides could reasonably accept.",
          "ko": "끝없는 논쟁에 넌더리가 난 대표들은 마침내 양측이 합리적으로 받아들일 수 있는 타협안을 모색했다.",
          "sort_order": 5
        }
      ]
    },
    "534": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "장치; 기기; 방법; 고안물",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "I bought a small device to charge my phone.",
          "ko": "나는 휴대폰을 충전할 작은 기기를 샀다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The new device that our school introduced helps students study math more easily.",
          "ko": "우리 학교가 도입한 새 기기는 학생들이 수학을 더 쉽게 공부하도록 돕는다.",
