    "662": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "실수하다; 잘못하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Everyone can err, so try not to worry too much.",
          "ko": "누구나 실수할 수 있으니 너무 걱정하지 마라.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The student erred in his answer because he had not read the question carefully.",
          "ko": "그 학생은 문제를 주의 깊게 읽지 않아서 답에서 실수했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When facing uncertainty, wise leaders prefer to err on the side of caution rather than make hasty decisions they might regret.",
          "ko": "불확실성에 직면할 때, 현명한 지도자들은 후회할 성급한 결정을 내리기보다 신중한 쪽으로 실수하는 편을 택한다.",
          "sort_order": 2
        }
      ]
    },
    "2154": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "창고; 물류 창고",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "창고에 보관하다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The workers moved the boxes into the large warehouse.",
          "ko": "일꾼들이 상자들을 큰 창고 안으로 옮겼다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The company built a new warehouse near the port so that goods could be shipped faster.",
          "ko": "그 회사는 상품을 더 빨리 운송할 수 있도록 항구 근처에 새 창고를 지었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Modern warehouses increasingly rely on automated robots and data systems to track inventory, reduce errors, and speed up global delivery networks.",
          "ko": "현대의 창고들은 재고를 추적하고 오류를 줄이며 세계적 배송망의 속도를 높이기 위해 자동화 로봇과 데이터 시스템에 점점 더 의존한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "They warehouse the extra products until spring.",
          "ko": "그들은 봄까지 여분의 제품을 창고에 보관한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The firm chose to warehouse its seasonal items in a rented space to save on rent.",
          "ko": "그 회사는 임대료를 절약하기 위해 계절 상품을 임대 공간에 창고 보관하기로 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Because storing surplus goods can tie up capital, managers must decide carefully how long to warehouse products before demand justifies the cost.",
          "ko": "잉여 상품을 보관하는 일이 자본을 묶어 둘 수 있기 때문에, 관리자는 수요가 그 비용을 정당화하기 전에 제품을 얼마나 오래 창고에 보관할지 신중히 결정해야 한다.",
          "sort_order": 2
        }
      ]
    },
    "931": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "만(灣); (큰) 격차, 간극",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We sailed our small boat across the calm gulf.",
          "ko": "우리는 잔잔한 만을 가로질러 작은 배를 몰았다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "There is a wide gulf between what people say and what they actually do.",
          "ko": "사람들이 말하는 것과 실제로 행동하는 것 사이에는 큰 간극이 있다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The growing gulf between rich and poor regions threatens social cohesion and undermines any collective effort toward sustainable development.",
          "ko": "부유한 지역과 가난한 지역 사이의 커지는 격차는 사회적 결속을 위협하고 지속 가능한 발전을 위한 모든 공동의 노력을 약화시킨다.",
          "sort_order": 2
        }
      ]
    },
