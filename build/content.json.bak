      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "A tear ran down her cheek during the sad movie.",
          "ko": "슬픈 영화를 보는 동안 눈물이 그녀의 뺨을 타고 흘렀다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "He wiped away a tear as he read the letter that his old friend had written.",
          "ko": "그는 옛 친구가 쓴 편지를 읽으며 눈물을 닦아냈다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Scientists explain that a single tear can carry chemical signals which reveal emotional states more accurately than facial expressions alone.",
          "ko": "과학자들은 한 방울의 눈물이 표정만으로 드러나는 것보다 더 정확하게 감정 상태를 드러내는 화학적 신호를 담을 수 있다고 설명한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Be careful not to tear the paper when you fold it.",
          "ko": "종이를 접을 때 찢어지지 않도록 조심해라.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "She began to tear the old letters into pieces because they reminded her of a painful memory.",
          "ko": "그녀는 그 편지들이 고통스러운 기억을 떠올리게 했기 때문에 오래된 편지들을 조각조각 찢기 시작했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Strong emotional conflicts can tear a community apart when its members fail to find common ground through honest dialogue.",
          "ko": "강한 감정적 갈등은 구성원들이 솔직한 대화를 통해 공통점을 찾지 못할 때 공동체를 갈가리 찢어놓을 수 있다.",
          "sort_order": 2
        }
      ]
    },
    "1737": {
