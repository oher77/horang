    "1454": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "참가하다; 참여하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Many students want to participate in the sports day.",
          "ko": "많은 학생들이 운동회에 참가하고 싶어 한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Teachers encourage everyone to participate in class discussions so that shy students can share ideas.",
          "ko": "교사들은 수줍은 학생들도 생각을 나눌 수 있도록 모두가 수업 토론에 참여하도록 격려한다.",
