      ],
      "examples": [
        {
          "pos": "phrase",
          "level": 1,
          "en": "The shop is having a clearance sale this weekend.",
          "ko": "그 가게는 이번 주말에 재고 정리 세일을 한다.",
          "sort_order": 0
        },
        {
          "pos": "phrase",
          "level": 2,
          "en": "Many students visited the mall because a huge clearance sale offered discounts on winter clothes.",
          "ko": "큰 재고 정리 세일이 겨울옷 할인을 제공했기 때문에 많은 학생들이 쇼핑몰을 찾았다.",
          "sort_order": 1
        },
        {
          "pos": "phrase",
          "level": 3,
          "en": "Retailers often launch a clearance sale at the end of a season to reduce unsold inventory and free up storage for newer products.",
          "ko": "소매업체들은 팔리지 않은 재고를 줄이고 신제품을 위한 창고 공간을 확보하기 위해 시즌 말에 재고 정리 세일을 시작하는 경우가 많다.",
          "sort_order": 2
        }
      ]
    },
