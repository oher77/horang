          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "She rolled the dough carefully so that the pizza base would be thin and even.",
          "ko": "그녀는 피자 도우가 얇고 고르게 되도록 반죽을 조심스럽게 밀었다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "As the massive stone began to roll down the slope, the villagers realized how quickly a small change could trigger a disaster.",
          "ko": "거대한 돌이 비탈을 굴러 내려가기 시작하자, 마을 사람들은 작은 변화가 얼마나 빨리 재앙을 촉발할 수 있는지 깨달았다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "He ate a warm bread roll for breakfast.",
          "ko": "그는 아침으로 따뜻한 롤빵을 먹었다.",
          "sort_order": 3
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher checked the roll to see which students were absent from class.",
          "ko": "선생님은 어떤 학생들이 결석했는지 확인하려고 명단을 점검했다.",
          "sort_order": 4
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Historians discovered an ancient roll of parchment whose faded text revealed how trade agreements were recorded centuries ago.",
          "ko": "역사학자들은 색이 바랜 글이 수 세기 전 무역 협정이 어떻게 기록되었는지를 보여 주는 고대의 양피지 두루마리를 발견했다.",
          "sort_order": 5
        }
      ]
    },
