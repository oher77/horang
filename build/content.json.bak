        }
      ],
      "examples": [
        {
          "pos": "ad",
          "level": 1,
          "en": "We stayed overnight at a small hotel near the beach.",
          "ko": "우리는 해변 근처의 작은 호텔에서 하룻밤 묵었다.",
          "sort_order": 0
        },
        {
          "pos": "ad",
          "level": 2,
          "en": "The singer became famous overnight after her video was shared by millions of people.",
          "ko": "그 가수는 영상이 수백만 명에게 공유된 뒤 하룻밤 사이에 유명해졌다.",
          "sort_order": 1
        },
        {
          "pos": "ad",
          "level": 2,
          "en": "Success in any field rarely happens overnight, even when talent is obvious to everyone.",
          "ko": "어떤 분야에서든 성공은 재능이 누구에게나 분명해도 하룻밤 사이에 이뤄지는 경우가 드물다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "He packed a small bag for the overnight trip.",
          "ko": "그는 하룻밤 여행을 위해 작은 가방을 쌌다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The school arranged an overnight stay so that students could observe the stars together.",
          "ko": "학교는 학생들이 함께 별을 관찰할 수 있도록 하룻밤 숙박을 마련했다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Economists warn that an overnight surge in prices can undermine consumer confidence and destabilize an otherwise steady market.",
          "ko": "경제학자들은 가격의 갑작스러운 급등이 소비자 신뢰를 약화시키고 안정적이던 시장을 불안정하게 만들 수 있다고 경고한다.",
          "sort_order": 2
        }
      ]
    },
    "722": {
      "meanings": [
