          "sort_order": 2
        }
      ]
    },
    "2052": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "실; (이야기·논의의) 맥락; (게시판의) 글타래",
          "sort_order": 0
        },
        {
