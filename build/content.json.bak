          "ko": "모든 저축을 한 회사에 투자하는 것은 당신의 전체 재정적 미래를 위협할 수 있는 위험한 도박이다.",
          "sort_order": 2
        }
      ]
    },
    "1824": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "긁다; 할퀴다; 긁어서 지우다",
