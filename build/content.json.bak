      "examples": [
        {
          "pos": "phrase",
          "level": 1,
          "en": "The baby kept crying all night long.",
          "ko": "아기는 밤새도록 계속 울었다.",
          "sort_order": 0
        },
        {
          "pos": "phrase",
          "level": 2,
          "en": "Even though he was tired, he kept studying until he finished the whole chapter.",
          "ko": "그는 피곤했지만 그 장을 다 끝낼 때까지 계속 공부했다.",
          "sort_order": 1
        },
        {
          "pos": "phrase",
          "level": 3,
          "en": "Successful people often keep trying new approaches even after several failures, because they view setbacks as valuable feedback rather than final defeats.",
          "ko": "성공한 사람들은 여러 번 실패한 후에도 흔히 새로운 방법을 계속 시도하는데, 이는 좌절을 최종적인 패배가 아니라 소중한 피드백으로 여기기 때문이다.",
          "sort_order": 2
        }
      ]
    },
    "2407": {
      "meanings": [
