    "357": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "제약하다; 제한하다; 강요하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Tight rules can constrain how children play outside.",
          "ko": "엄격한 규칙은 아이들이 밖에서 노는 방식을 제한할 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "A limited budget will constrain the choices that the school can make next year.",
          "ko": "제한된 예산은 학교가 내년에 할 수 있는 선택을 제약할 것이다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Social norms often constrain individuals from expressing opinions that might challenge the values widely accepted by their community.",
          "ko": "사회적 규범은 흔히 개인이 자신의 공동체가 널리 받아들이는 가치에 도전할 수 있는 의견을 표현하는 것을 제약한다.",
          "sort_order": 2
        }
      ]
    },
    "456": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "냉소적인; 비꼬는; 회의적인",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "He gave a cynical smile at the news.",
          "ko": "그는 그 소식에 냉소적인 미소를 지었다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "She became cynical about promises after so many politicians broke them.",
          "ko": "그녀는 너무 많은 정치인들이 약속을 어긴 후 약속에 대해 냉소적이 되었다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Many students grow cynical when adults say one thing but clearly do another.",
          "ko": "많은 학생들은 어른들이 말과 행동이 다를 때 냉소적으로 변한다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 3,
          "en": "A cynical view of human nature assumes that people are ultimately driven by self-interest, yet such assumptions often overlook genuine acts of altruism.",
          "ko": "인간 본성에 대한 냉소적인 시각은 사람들이 궁극적으로 사리사욕에 의해 움직인다고 가정하지만, 그러한 가정은 종종 진정한 이타적 행동을 간과한다.",
          "sort_order": 3
        }
      ]
    },
    "1682": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "조리법; 요리법; 비결",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My mom followed a simple recipe to make the soup.",
          "ko": "엄마는 간단한 조리법을 따라 그 수프를 만드셨다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The chef shared a recipe that anyone can cook at home without special tools.",
          "ko": "그 요리사는 특별한 도구 없이 누구나 집에서 만들 수 있는 조리법을 공유했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Experts argue that constant stress combined with little sleep is a recipe for serious health problems in modern society.",
          "ko": "전문가들은 지속적인 스트레스와 부족한 수면이 결합되면 현대 사회에서 심각한 건강 문제의 원인이 된다고 주장한다.",
          "sort_order": 2
        }
      ]
    },
    "1621": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "보호하다; 지키다; 막다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "We should protect animals from danger.",
          "ko": "우리는 동물들을 위험으로부터 보호해야 한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The new law was created to protect workers who report unfair treatment at their jobs.",
          "ko": "그 새로운 법은 직장에서 부당한 대우를 신고하는 노동자들을 보호하기 위해 만들어졌다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Governments must protect fragile ecosystems from industrial pollution, since the collapse of a single species can disturb an entire food chain.",
          "ko": "정부는 취약한 생태계를 산업 오염으로부터 보호해야 하는데, 단 하나의 종이 붕괴되어도 전체 먹이 사슬을 교란할 수 있기 때문이다.",
          "sort_order": 2
        }
      ]
    },
    "282": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "동시에 일어나다; 일치하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Our holidays happened to coincide this year.",
          "ko": "올해 우리의 휴가가 우연히 겹쳤다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The concert will coincide with the festival, so the town expects a large crowd.",
          "ko": "그 콘서트가 축제와 겹치기 때문에 마을은 많은 인파를 예상한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Her views on the topic closely coincide with those of her mentor.",
          "ko": "그 주제에 대한 그녀의 견해는 그녀의 멘토의 견해와 상당히 일치한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When economic downturns coincide with political instability, governments often struggle to implement long-term reforms that require public trust.",
          "ko": "경제 침체가 정치적 불안정과 맞물릴 때, 정부는 대중의 신뢰를 필요로 하는 장기 개혁을 시행하는 데 종종 어려움을 겪는다.",
          "sort_order": 3
        }
      ]
    },
    "1111": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "기쁨; 즐거움; 환희",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The children jumped with joy at the news.",
          "ko": "아이들은 그 소식에 기뻐서 뛰었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "She felt great joy when she found the letter that her friend had written.",
          "ko": "그녀는 친구가 쓴 편지를 발견했을 때 큰 기쁨을 느꼈다.",
