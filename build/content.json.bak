        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "A travel agent helped us book the cheap flight.",
          "ko": "여행사 직원이 우리가 싼 항공편을 예약하도록 도와주었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The famous actor hired a new agent who could negotiate better contracts with studios.",
          "ko": "그 유명 배우는 스튜디오와 더 좋은 계약을 협상할 수 있는 새 에이전트를 고용했다.",
          "sort_order": 1
