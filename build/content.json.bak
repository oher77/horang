        {
          "pos": "n",
          "level": 2,
          "en": "The painting captures a winter landscape where snow covers the quiet village.",
          "ko": "그 그림은 눈이 고요한 마을을 뒤덮은 겨울 풍경을 담고 있다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The rapid rise of digital media has transformed the entire landscape of how people access and evaluate information.",
          "ko": "디지털 미디어의 급속한 부상은 사람들이 정보에 접근하고 평가하는 방식의 전체 지형을 바꾸어 놓았다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "They plan to landscape the yard next spring.",
          "ko": "그들은 내년 봄에 마당을 조경할 계획이다.",
          "sort_order": 3
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The city hired workers to landscape the park so that families could relax there.",
          "ko": "시는 가족들이 그곳에서 쉴 수 있도록 공원을 조경할 인부를 고용했다.",
          "sort_order": 4
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Architects increasingly landscape urban spaces with native plants, aiming to restore ecosystems while reducing the cost of maintenance.",
          "ko": "건축가들은 유지 비용을 줄이면서 생태계를 복원하고자, 점점 더 토착 식물로 도시 공간을 조경한다.",
          "sort_order": 5
        }
      ]
    },
    "379": {
      "meanings": [
