      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "She gave the room a thorough cleaning today.",
          "ko": "그녀는 오늘 방을 철저하게 청소했다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Before the exam, the teacher gave us a thorough review of every chapter we studied.",
          "ko": "시험 전에 선생님은 우리가 공부한 모든 단원을 철저하게 복습해 주셨다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
