    "307": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "회사; 동료; 함께 있음",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "동행하다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My father works for a big company in the city.",
          "ko": "우리 아버지는 도시에 있는 큰 회사에서 일하신다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The company decided to hire more workers because sales grew quickly last year.",
          "ko": "작년에 매출이 빠르게 성장했기 때문에 그 회사는 더 많은 직원을 고용하기로 결정했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "She enjoyed the company of her friends after a long and stressful week at school.",
          "ko": "그녀는 힘들고 스트레스가 많았던 한 주 뒤에 친구들과 함께 있는 것을 즐겼다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Psychologists suggest that the mere company of others can significantly reduce the anxiety people feel in unfamiliar or threatening situations.",
          "ko": "심리학자들은 단지 다른 사람들과 함께 있는 것만으로도 낯설거나 위협적인 상황에서 사람들이 느끼는 불안을 크게 줄일 수 있다고 말한다.",
          "sort_order": 3
        }
      ]
    },
    "1712": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "의지하다; 신뢰하다; 믿다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "You can rely on your best friend for help.",
          "ko": "너는 도움이 필요할 때 가장 친한 친구에게 의지할 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many students rely on the internet when they search for information about their projects.",
          "ko": "많은 학생들이 과제에 관한 정보를 찾을 때 인터넷에 의존한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Modern societies increasingly rely on complex technologies whose inner workings few citizens actually understand or can control.",
          "ko": "현대 사회는 그 내부 작동을 실제로 이해하거나 통제할 수 있는 시민이 거의 없는 복잡한 기술에 점점 더 의존한다.",
          "sort_order": 2
        }
      ]
    },
    "1287": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "최소; 최저치",
          "sort_order": 0
        },
        {
          "pos": "a",
          "meaning_ko": "최소의; 최저의",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "You need a minimum of two people to play this game.",
          "ko": "이 게임을 하려면 최소 두 명이 필요하다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher told us to write at least the minimum, which was five hundred words.",
          "ko": "선생님은 최소치인 500단어는 써야 한다고 우리에게 말했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Economists argue that keeping inflation to a minimum is essential if a government hopes to maintain long-term public trust.",
          "ko": "경제학자들은 정부가 장기적인 국민 신뢰를 유지하려면 인플레이션을 최소로 억제하는 것이 필수적이라고 주장한다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "The minimum age to enter the park is seven.",
          "ko": "그 공원에 입장할 수 있는 최소 나이는 일곱 살이다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Many students take part-time jobs that pay only the minimum wage set by law.",
          "ko": "많은 학생들이 법으로 정해진 최저 임금만 주는 아르바이트를 한다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "The company must meet the minimum safety standards required by regulations before its new factory can begin operation.",
          "ko": "그 회사는 새 공장이 가동을 시작하기 전에 규정이 요구하는 최소 안전 기준을 충족해야 한다.",
          "sort_order": 2
        }
      ]
    },
    "567": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "왜곡하다; 비틀다; 일그러뜨리다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The old mirror can distort your face a little.",
          "ko": "그 낡은 거울은 네 얼굴을 조금 일그러뜨릴 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Some newspapers distort the facts so that readers will feel angry or afraid.",
          "ko": "일부 신문은 독자가 분노하거나 두려움을 느끼도록 사실을 왜곡한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Cognitive biases often distort our memories, leading us to reconstruct past events in ways that confirm our current beliefs.",
          "ko": "인지 편향은 흔히 우리의 기억을 왜곡하여, 현재의 믿음을 확증하는 방식으로 과거 사건을 재구성하게 만든다.",
          "sort_order": 2
        }
      ]
    },
    "1311": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "기분; 분위기; 심기",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She is in a good mood today.",
          "ko": "그녀는 오늘 기분이 좋다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The soft music created a calm mood that helped the students focus on their work.",
          "ko": "부드러운 음악은 학생들이 공부에 집중하도록 돕는 차분한 분위기를 만들었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Psychologists suggest that a person's mood can shape decisions far more than we consciously realize, subtly biasing our judgments.",
          "ko": "심리학자들은 사람의 기분이 우리가 의식적으로 깨닫는 것보다 훨씬 더 결정을 좌우하며 우리의 판단을 미묘하게 편향시킬 수 있다고 말한다.",
          "sort_order": 2
        }
      ]
    },
    "381": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "유죄를 선고하다; 유죄로 판결하다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "죄수; 기결수",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The court will convict him if the proof is clear.",
          "ko": "증거가 명확하면 법원은 그에게 유죄를 선고할 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The jury voted to convict the man after they reviewed all the evidence carefully.",
          "ko": "배심원단은 모든 증거를 신중히 검토한 뒤 그 남자에게 유죄를 선고하기로 표결했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "A fair legal system should never convict a defendant unless the prosecution proves guilt beyond any reasonable doubt.",
          "ko": "공정한 법 제도는 검찰이 합리적 의심을 넘어 유죄를 입증하지 않는 한 결코 피고인에게 유죄를 선고해서는 안 된다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "The convict tried to escape from the prison.",
          "ko": "그 죄수는 감옥에서 탈출하려고 했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "An escaped convict was captured by the police who had searched the whole area.",
          "ko": "탈옥한 죄수는 그 일대를 수색한 경찰에게 붙잡혔다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Many programs aim to help each convict reintegrate into society, offering vocational training that reduces the likelihood of future crimes.",
          "ko": "많은 프로그램이 각 죄수가 사회에 재통합하도록 돕는 것을 목표로 하며, 향후 범죄 가능성을 낮추는 직업 훈련을 제공한다.",
          "sort_order": 2
        }
      ]
    },
    "1123": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "기사; (체스의) 나이트",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "기사 작위를 수여하다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The brave knight rode a white horse into the castle.",
          "ko": "용감한 기사가 백마를 타고 성 안으로 들어갔다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "In the story, the young knight who defended the village became a hero to everyone.",
          "ko": "이야기에서 마을을 지킨 젊은 기사는 모두에게 영웅이 되었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Medieval society idealized the knight as a figure who balanced martial skill with a strict code of honor and loyalty.",
          "ko": "중세 사회는 기사를 무예 실력과 엄격한 명예·충성의 규범을 조화시키는 인물로 이상화했다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The king will knight the loyal soldier tomorrow.",
          "ko": "왕은 내일 그 충직한 병사에게 기사 작위를 수여할 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The queen decided to knight the scientist who had greatly helped the nation.",
          "ko": "여왕은 나라에 크게 기여한 그 과학자에게 기사 작위를 수여하기로 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "To knight a commoner for extraordinary achievement was once a rare gesture that reflected shifting ideas about merit and social rank.",
          "ko": "평민을 비범한 업적으로 기사에 봉하는 것은 한때 공적과 사회적 신분에 대한 변화하는 관념을 반영한 드문 행위였다.",
          "sort_order": 2
        }
      ]
    },
    "1996": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "대신하다; 대체하다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "대체물; 대리인; 교체 선수",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "You can substitute honey for sugar in this recipe.",
          "ko": "이 요리법에서는 설탕 대신 꿀을 쓸 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "When the teacher was sick, another one substituted for her during the class.",
          "ko": "선생님이 아프셨을 때 다른 선생님이 수업 동안 그녀를 대신했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Economists warn that machines cannot fully substitute for human judgment when complex ethical decisions must be made.",
          "ko": "경제학자들은 복잡한 윤리적 결정을 내려야 할 때 기계가 인간의 판단을 완전히 대체할 수는 없다고 경고한다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "Milk is a good substitute for cream.",
          "ko": "우유는 크림의 좋은 대체품이다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The coach sent in a substitute because the player looked too tired to continue.",
          "ko": "코치는 그 선수가 너무 지쳐 보여서 교체 선수를 투입했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Online communication, however convenient, remains a poor substitute for the emotional depth of face-to-face conversation.",
          "ko": "온라인 소통은 아무리 편리하더라도 대면 대화의 정서적 깊이를 대신하기에는 여전히 부족한 대체물이다.",
          "sort_order": 2
        }
      ]
    },
    "440": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "경작하다; 재배하다; (능력·관계를) 기르다, 함양하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Farmers cultivate rice in these wide fields.",
          "ko": "농부들은 이 넓은 들판에서 벼를 재배한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher tried to cultivate a habit of reading among the students in her class.",
          "ko": "그 교사는 자기 반 학생들 사이에 독서 습관을 기르려고 노력했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "To succeed in a global society, individuals must cultivate the ability to understand perspectives that differ greatly from their own.",
          "ko": "세계화된 사회에서 성공하려면 개인은 자신의 것과 크게 다른 관점을 이해하는 능력을 함양해야 한다.",
          "sort_order": 2
        }
      ]
    },
    "1722": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "대체하다; 교체하다; 대신하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I need to replace the batteries in this clock.",
          "ko": "나는 이 시계의 건전지를 교체해야 한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The company decided to replace old machines with newer ones to save energy.",
          "ko": "그 회사는 에너지를 절약하기 위해 낡은 기계를 새 기계로 교체하기로 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 2,
          "en": "No one can replace a good friend who has always listened to your worries.",
          "ko": "당신의 걱정을 늘 들어준 좋은 친구를 대신할 수 있는 사람은 없다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 3,
          "en": "As automation advances, machines increasingly replace human labor in repetitive tasks, forcing societies to redefine the meaning of meaningful work.",
          "ko": "자동화가 발전하면서 기계가 반복적인 작업에서 인간 노동을 점점 더 대체하고 있으며, 이는 사회가 의미 있는 일의 정의를 다시 세우도록 강요한다.",
          "sort_order": 3
        }
      ]
    },
    "1273": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "대도시의; 수도권의",
