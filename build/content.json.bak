      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I want to join the school soccer club this year.",
          "ko": "나는 올해 학교 축구부에 가입하고 싶다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many students joined the volunteer program because it offered valuable experience for their future careers.",
          "ko": "많은 학생들이 미래의 진로에 값진 경험을 준다는 이유로 그 봉사 프로그램에 참여했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When neighboring communities join forces to address shared problems, they often achieve results that no single group could accomplish alone.",
          "ko": "이웃한 공동체들이 공동의 문제를 해결하기 위해 힘을 합칠 때, 그들은 어떤 한 집단도 홀로 이룰 수 없는 성과를 종종 달성한다.",
          "sort_order": 2
        }
      ]
    },
    "740": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "팬; 애호가",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "선풍기; 부채",
