      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The city will impose a new tax on plastic bags.",
          "ko": "그 도시는 비닐봉지에 새로운 세금을 부과할 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher decided to impose stricter rules because many students kept arriving late.",
          "ko": "많은 학생들이 계속 늦게 오자 선생님은 더 엄격한 규칙을 부과하기로 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Governments should be cautious not to impose regulations that unintentionally restrict the very freedoms they aim to protect.",
          "ko": "정부는 보호하려는 바로 그 자유를 의도치 않게 제한하는 규제를 부과하지 않도록 신중해야 한다.",
          "sort_order": 2
        }
      ]
    },
    "1116": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "열망하는; 열정적인; 예리한, 날카로운",
