        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "This ticket will entitle you to a free drink.",
          "ko": "이 표는 당신에게 무료 음료를 받을 자격을 준다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Members who pay the annual fee are entitled to use every facility in the club.",
          "ko": "연회비를 내는 회원들은 클럽의 모든 시설을 이용할 자격이 있다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "The new law entitles part-time workers to the same medical benefits that full-time employees have long received.",
          "ko": "새 법은 시간제 근로자들에게 정규직 직원들이 오랫동안 받아 온 것과 동일한 의료 혜택을 받을 권리를 부여한다.",
          "sort_order": 2
        }
      ]
    },
    "449": {
      "meanings": [
