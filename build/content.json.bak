    "2290": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "세대; 발생; 생성",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My grandmother's generation lived without smartphones.",
          "ko": "우리 할머니 세대는 스마트폰 없이 살았다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The younger generation, which grew up online, often communicates in very different ways.",
          "ko": "온라인에서 자란 젊은 세대는 흔히 매우 다른 방식으로 소통한다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The generation of renewable energy from wind and sunlight has become essential as societies seek to reduce their dependence on fossil fuels.",
          "ko": "사회가 화석 연료 의존도를 줄이려 함에 따라 바람과 햇빛으로부터 재생 에너지를 생성하는 것이 필수가 되었다.",
          "sort_order": 2
        }
      ]
    },
    "1071": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "지성; 지능; 지식인",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She used her intellect to solve the hard puzzle.",
          "ko": "그녀는 어려운 퍼즐을 풀기 위해 자신의 지성을 사용했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "His sharp intellect, which impressed all the teachers, helped him win the debate contest.",
          "ko": "모든 교사에게 깊은 인상을 준 그의 예리한 지성은 그가 토론 대회에서 우승하도록 도왔다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Great scientific breakthroughs often depend not only on raw intellect but also on the patience to question assumptions that others accept without doubt.",
          "ko": "위대한 과학적 돌파구는 순수한 지성뿐만 아니라 남들이 의심 없이 받아들이는 가정을 의문시하는 인내에도 종종 달려 있다.",
          "sort_order": 2
        }
      ]
    },
