          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "You can obtain a free ticket at the front desk.",
          "ko": "안내데스크에서 무료 티켓을 얻을 수 있다.",
          "sort_order": 0
