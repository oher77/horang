        {
          "pos": "n",
          "level": 3,
          "en": "The report included a short extract from an ancient text, offering readers a rare glimpse into a forgotten civilization.",
          "ko": "그 보고서는 고대 문헌의 짧은 발췌를 포함하여, 독자들에게 잊힌 문명을 엿볼 드문 기회를 제공했다.",
          "sort_order": 2
        }
      ]
    },
    "404": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "상대방; 대응하는 사람; 대응물",
