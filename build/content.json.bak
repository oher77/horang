    "2319": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "수학",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "I have a math test tomorrow morning.",
          "ko": "나는 내일 아침에 수학 시험이 있다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Many students find math difficult because they memorize formulas without understanding them.",
          "ko": "많은 학생들이 공식을 이해하지 않고 외우기 때문에 수학을 어려워한다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Our teacher said that practicing math regularly is more helpful than studying all night before an exam.",
          "ko": "우리 선생님은 시험 전날 밤새 공부하는 것보다 수학을 꾸준히 연습하는 것이 더 도움이 된다고 말씀하셨다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Researchers argue that strong math skills develop not from natural talent alone but from consistent effort and a willingness to embrace mistakes.",
          "ko": "연구자들은 뛰어난 수학 능력이 타고난 재능만으로가 아니라 꾸준한 노력과 실수를 기꺼이 받아들이는 태도에서 길러진다고 주장한다.",
          "sort_order": 3
        }
      ]
    },
    "1148": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "세탁물; 빨래; 세탁소",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "I need to do the laundry this morning.",
          "ko": "나는 오늘 아침에 빨래를 해야 한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "After the busy week, a huge pile of laundry was waiting for me at home.",
          "ko": "바쁜 한 주가 지난 뒤, 집에는 엄청난 양의 빨래가 나를 기다리고 있었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Modern washing machines have reduced the time families spend on laundry, allowing them to devote more energy to other meaningful activities.",
          "ko": "현대의 세탁기는 가족들이 빨래에 쓰는 시간을 줄여 주어, 다른 의미 있는 활동에 더 많은 에너지를 쏟을 수 있게 해 주었다.",
          "sort_order": 2
        }
      ]
    },
    "2253": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "서랍; 제도사; 어음 발행인",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She put the spoons in the top drawer.",
          "ko": "그녀는 숟가락을 맨 위 서랍에 넣었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "He opened the desk drawer where he usually kept his old letters and photos.",
          "ko": "그는 평소 오래된 편지와 사진을 보관하던 책상 서랍을 열었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Investigators found the missing documents hidden in a locked drawer that no one else had access to.",
          "ko": "조사관들은 다른 누구도 접근할 수 없었던 잠긴 서랍에 숨겨진 사라진 문서들을 발견했다.",
          "sort_order": 2
        }
      ]
    },
    "33": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "존경하다; 감탄하다; 칭찬하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I really admire my grandmother for her kindness.",
          "ko": "나는 할머니의 친절함을 정말 존경한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many students admire the teacher who always listens to their problems patiently.",
          "ko": "많은 학생들은 항상 그들의 문제를 인내심 있게 들어 주는 그 선생님을 존경한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Historians admire leaders who managed to unite divided societies without resorting to force or fear during periods of great uncertainty.",
          "ko": "역사가들은 큰 불확실성의 시기에 무력이나 공포에 의존하지 않고 분열된 사회를 통합해 낸 지도자들을 존경한다.",
          "sort_order": 2
        }
      ]
    },
    "419": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "크레용, 크레파스",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The little boy drew a sun with a yellow crayon.",
          "ko": "그 어린 소년은 노란 크레용으로 해를 그렸다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Each student was given a box of crayons so that they could color the map together.",
          "ko": "각 학생은 함께 지도에 색칠할 수 있도록 크레용 한 상자를 받았다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Art teachers often begin with a simple crayon because its bold texture encourages young children to express emotions without fearing mistakes.",
          "ko": "미술 교사들은 흔히 단순한 크레용으로 시작하는데, 그 강한 질감이 어린아이들로 하여금 실수를 두려워하지 않고 감정을 표현하도록 격려하기 때문이다.",
          "sort_order": 2
        }
      ]
    },
    "3": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "중단하다; 중지하다; 낙태하다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "중단; (임무의) 취소",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "They had to abort the trip because of the storm.",
          "ko": "그들은 폭풍 때문에 여행을 중단해야 했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The pilot chose to abort the takeoff when a warning light suddenly flashed.",
          "ko": "조종사는 경고등이 갑자기 켜지자 이륙을 중단하기로 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Engineers decided to abort the launch after sensors detected a fuel leak that could endanger the entire mission.",
          "ko": "기술자들은 센서가 임무 전체를 위험에 빠뜨릴 수 있는 연료 누출을 감지하자 발사를 중단하기로 결정했다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "The launch ended in an abort at the last second.",
          "ko": "발사는 마지막 순간에 중단으로 끝났다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The crew reported an abort because a critical system failed during the countdown.",
          "ko": "승무원들은 카운트다운 중 중요한 시스템이 고장 나 임무 중단을 보고했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A last-minute abort of the operation, though costly, was justified as the only way to protect the safety of everyone involved.",
          "ko": "막바지의 작전 중단은 비용이 많이 들었지만 관련된 모든 이의 안전을 지키는 유일한 방법으로 정당화되었다.",
          "sort_order": 2
        }
      ]
    },
    "2283": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "격식을 차린; 공식적인; 정식의",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "You should wear formal clothes to the interview.",
          "ko": "면접에는 격식을 차린 옷을 입어야 한다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The school held a formal ceremony to welcome the new students who had just arrived.",
          "ko": "학교는 막 도착한 신입생들을 환영하기 위해 공식적인 행사를 열었다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "In academic writing, a formal tone is expected because it conveys objectivity and lends credibility to the argument being presented.",
          "ko": "학술적 글쓰기에서는 격식 있는 어조가 요구되는데, 그것이 객관성을 전달하고 제시되는 주장에 신뢰성을 부여하기 때문이다.",
          "sort_order": 2
        }
      ]
    },
    "1890": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "수줍은; 부끄러워하는; 소심한",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "뒷걸음질치다; 겁내어 피하다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "The shy boy did not want to speak in class.",
          "ko": "그 수줍은 소년은 수업 시간에 말하기를 원하지 않았다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Although she seemed shy at first, she became very talkative once we got to know her.",
          "ko": "그녀는 처음에는 수줍어 보였지만, 우리가 그녀를 알게 되자 매우 수다스러워졌다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Many students who appear shy in large lectures actually contribute thoughtful ideas when they feel safe in smaller discussion groups.",
          "ko": "대규모 강의에서 수줍어 보이는 많은 학생들은 소규모 토론 그룹에서 안전하다고 느낄 때 실제로는 사려 깊은 아이디어를 내놓는다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The horse tends to shy at loud noises.",
          "ko": "그 말은 시끄러운 소리에 뒷걸음질치는 경향이 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Some people shy away from new challenges because they are afraid of making mistakes.",
          "ko": "어떤 사람들은 실수하는 것을 두려워하기 때문에 새로운 도전을 피한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Investors often shy away from unfamiliar markets, even when the potential returns clearly outweigh the perceived risks involved.",
          "ko": "투자자들은 잠재적 수익이 인식된 위험보다 분명히 클 때조차도 낯선 시장을 피하는 경우가 많다.",
          "sort_order": 2
        }
      ]
    },
    "1998": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "교외; 근교",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My uncle lives in a quiet suburb near the city.",
          "ko": "내 삼촌은 도시 근처의 조용한 교외에 산다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Many families move to the suburb because it offers cheaper houses and better schools.",
          "ko": "많은 가족이 더 싼 집과 더 좋은 학교를 제공하는 교외로 이사한다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "As commuting costs rose, planners studied how the expanding suburb reshaped daily patterns of work, consumption, and social interaction.",
          "ko": "통근 비용이 오르면서, 도시계획가들은 확장되는 교외가 일과 소비, 사회적 상호작용의 일상 패턴을 어떻게 재편했는지 연구했다.",
          "sort_order": 2
        }
      ]
    },
    "2203": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "명확히 하다; 분명히 밝히다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Can you clarify what you mean by that word?",
          "ko": "그 단어가 무슨 뜻인지 명확히 해 줄 수 있나요?",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher paused to clarify the rule that many students had misunderstood.",
          "ko": "선생님은 많은 학생들이 오해한 규칙을 명확히 하려고 잠시 멈췄다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "A well-designed diagram can clarify complex relationships that would otherwise remain confusing in a dense written explanation.",
          "ko": "잘 설계된 도표는 빽빽한 서술 설명에서라면 혼란스럽게 남았을 복잡한 관계를 명확히 해 줄 수 있다.",
          "sort_order": 2
        }
      ]
    },
    "2016": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "항복하다; 넘겨주다; 포기하다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "항복; 굴복; 양도",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The soldiers had to surrender after the long battle.",
          "ko": "그 병사들은 긴 전투 끝에 항복해야 했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "He refused to surrender his dream even though everyone told him to give up.",
          "ko": "모두가 그에게 포기하라고 말했지만 그는 자신의 꿈을 포기하기를 거부했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Faced with overwhelming evidence, the company was finally forced to surrender its exclusive rights to the disputed technology.",
          "ko": "압도적인 증거에 직면하자, 그 회사는 결국 논란이 된 기술에 대한 독점권을 넘겨줄 수밖에 없었다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "The enemy raised a white flag as a sign of surrender.",
          "ko": "적군은 항복의 표시로 백기를 들었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The general demanded an immediate surrender before the negotiations could even begin.",
          "ko": "장군은 협상이 시작되기도 전에 즉각적인 항복을 요구했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "For some philosophers, the surrender of individual freedom to collective authority is the very foundation of a functioning society.",
          "ko": "일부 철학자에게 개인의 자유를 집단적 권위에 양도하는 것은 기능하는 사회의 바로 그 토대이다.",
          "sort_order": 2
        }
      ]
    },
    "716": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "연장하다; 늘리다; 확장하다; 뻗다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "We want to extend our trip by two more days.",
          "ko": "우리는 여행을 이틀 더 연장하고 싶다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The library decided to extend its opening hours so that students could study longer.",
          "ko": "도서관은 학생들이 더 오래 공부할 수 있도록 개관 시간을 연장하기로 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "The government plans to extend social welfare programs to rural regions where access to public services has long been limited.",
          "ko": "정부는 공공 서비스 접근이 오랫동안 제한되어 온 농촌 지역으로 사회 복지 프로그램을 확대할 계획이다.",
          "sort_order": 2
        }
      ]
    },
    "2316": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "~할 것 같지 않은; 있음직하지 않은",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "It is unlikely to rain today, so leave the umbrella.",
          "ko": "오늘은 비가 올 것 같지 않으니 우산을 두고 가라.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Although he studied little, it seems unlikely that he will fail the important exam.",
          "ko": "그는 공부를 거의 하지 않았지만, 중요한 시험에 떨어질 것 같지는 않아 보인다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Given the current economic conditions, experts consider it highly unlikely that prices will drop significantly within this year.",
          "ko": "현재의 경제 상황을 고려할 때, 전문가들은 올해 안에 물가가 크게 떨어질 가능성은 매우 낮다고 본다.",
          "sort_order": 2
        }
      ]
    },
    "1255": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "약; 의학; 의료",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Take this medicine twice a day after meals.",
          "ko": "이 약을 하루에 두 번 식사 후에 드세요.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "She studied medicine at university because she wanted to help sick people.",
          "ko": "그녀는 아픈 사람들을 돕고 싶어서 대학에서 의학을 공부했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The doctor warned that taking too much medicine can harm your health.",
          "ko": "의사는 약을 너무 많이 복용하면 건강을 해칠 수 있다고 경고했다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Modern medicine has advanced so rapidly that diseases once considered fatal can now be treated with remarkable precision.",
          "ko": "현대 의학은 매우 빠르게 발전하여 한때 치명적으로 여겨지던 질병들이 이제는 놀라운 정밀함으로 치료될 수 있다.",
          "sort_order": 3
        }
      ]
    },
    "987": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "지평선; 수평선; 시야, 범위",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The sun slowly went down below the horizon.",
          "ko": "해가 천천히 지평선 아래로 졌다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "As we sailed farther, the ship on the horizon grew smaller until it vanished.",
          "ko": "우리가 더 멀리 항해할수록 수평선 위의 배는 사라질 때까지 점점 작아졌다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Traveling to new countries can broaden your horizons and change how you see the world.",
          "ko": "새로운 나라로 여행하는 것은 당신의 시야를 넓히고 세상을 보는 방식을 바꿀 수 있다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Reading widely across disciplines expands one's intellectual horizons and cultivates the flexibility needed to solve unfamiliar problems.",
          "ko": "여러 분야를 폭넓게 읽는 것은 지적 시야를 확장하고 낯선 문제를 해결하는 데 필요한 유연성을 길러 준다.",
          "sort_order": 3
        }
      ]
    },
    "1597": {
      "meanings": [
