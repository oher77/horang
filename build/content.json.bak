      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The man was arrested for a violent assault last night.",
          "ko": "그 남자는 어젯밤 폭행으로 체포되었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The soldiers launched a sudden assault on the enemy base while it was still dark.",
          "ko": "병사들은 아직 어두울 때 적 기지에 대한 기습 공격을 개시했다.",
