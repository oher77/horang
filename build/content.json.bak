        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The store has a large stock of fresh fruit.",
          "ko": "그 가게는 신선한 과일 재고가 많다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "She bought some stock in a company that makes electric cars.",
          "ko": "그녀는 전기차를 만드는 회사의 주식을 조금 샀다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Because prices of stock can rise or fall sharply, investors are advised to study market trends before committing their savings.",
          "ko": "주식 가격은 급격히 오르내릴 수 있으므로, 투자자들은 저축을 투자하기 전에 시장 동향을 연구하라는 조언을 받는다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "We need to stock the fridge with milk and eggs.",
          "ko": "우리는 냉장고에 우유와 달걀을 채워 넣어야 한다.",
          "sort_order": 0
