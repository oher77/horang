          "meaning_ko": "대중; 일반 사람들",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "There is a public park near my house.",
          "ko": "우리 집 근처에 공공 공원이 있다.",
