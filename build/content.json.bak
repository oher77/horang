    "487": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "결핍; 부족; 결함",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "A lack of sleep can cause a vitamin deficiency.",
          "ko": "잠이 부족하면 비타민 결핍이 생길 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The doctor explained that her tiredness came from an iron deficiency in her blood.",
          "ko": "의사는 그녀의 피로가 혈액의 철분 결핍에서 온 것이라고 설명했다.",
