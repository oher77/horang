      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The candle began to glow in the dark room.",
          "ko": "촛불이 어두운 방에서 빛나기 시작했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Her face seemed to glow with joy when she heard the good news.",
          "ko": "좋은 소식을 들었을 때 그녀의 얼굴은 기쁨으로 상기된 듯했다.",
