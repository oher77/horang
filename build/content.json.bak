      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "My mom got mad when I broke the plate.",
          "ko": "내가 접시를 깨뜨리자 엄마가 화를 내셨다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "He was so mad about football that he practiced every day after school.",
          "ko": "그는 축구에 너무 열광해서 방과 후 매일 연습했다.",
