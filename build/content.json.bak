      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "The river is very broad near the old bridge.",
          "ko": "그 강은 낡은 다리 근처에서 매우 넓다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The new course covers a broad range of topics that most students find useful.",
          "ko": "새 강좌는 대부분의 학생들이 유용하다고 느끼는 광범위한 주제를 다룬다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "A broad consensus among scientists suggests that human activity has significantly altered the planet's climate over recent decades.",
          "ko": "과학자들 사이의 광범위한 합의는 인간 활동이 최근 수십 년간 지구 기후를 상당히 변화시켰음을 시사한다.",
          "sort_order": 2
        }
      ]
    },
    "679": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "사악한; 나쁜; 해로운",
