      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The club wants to recruit new members this spring.",
          "ko": "그 동아리는 이번 봄에 새 회원을 모집하고 싶어 한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The company plans to recruit young workers who are skilled in digital technology.",
          "ko": "그 회사는 디지털 기술에 능숙한 젊은 인력을 채용할 계획이다.",
          "sort_order": 1
