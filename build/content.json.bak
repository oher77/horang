    "694": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "변명; 이유; 핑계",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "용서하다; 변명하다; 면제하다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "He always has an excuse for being late.",
          "ko": "그는 늦은 것에 대해 항상 변명거리가 있다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher did not accept his excuse because he had missed the class again.",
          "ko": "그가 다시 수업에 빠졌기 때문에 선생님은 그의 변명을 받아들이지 않았다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Many people offer plausible excuses for procrastination, yet these justifications rarely address the underlying fear of failure.",
          "ko": "많은 사람들이 미루기에 대한 그럴듯한 변명을 내놓지만, 그러한 정당화는 실패에 대한 근본적인 두려움을 좀처럼 다루지 않는다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Please excuse me for interrupting you.",
          "ko": "방해해서 죄송합니다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher excused the students who had a good reason for being absent.",
          "ko": "선생님은 결석에 정당한 이유가 있는 학생들을 용서해 주었다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "We should not excuse dishonest behavior simply because it produces results that appear beneficial to the community.",
          "ko": "결과가 공동체에 이로워 보인다는 이유만으로 정직하지 못한 행동을 용서해서는 안 된다.",
          "sort_order": 2
        }
      ]
    },
    "1487": {
