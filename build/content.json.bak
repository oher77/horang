      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "You must vacate the room before noon.",
          "ko": "당신은 정오 전에 방을 비워야 한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The tenants were asked to vacate the building because it needed urgent repairs.",
          "ko": "세입자들은 그 건물이 긴급한 수리가 필요했기 때문에 건물을 비워 달라는 요청을 받았다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When a senior official chooses to vacate a position early, the resulting vacancy often triggers unexpected shifts in the entire organization.",
          "ko": "고위 관료가 일찍 자리를 떠나기로 결정할 때, 그로 인한 공석은 종종 조직 전체에 예상치 못한 변화를 촉발한다.",
          "sort_order": 2
        }
      ]
    },
    "1838": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "씨앗; 종자; 근원",
