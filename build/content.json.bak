      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My uncle is a member of the workers' union.",
          "ko": "삼촌은 노동조합의 회원이다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teachers' union asked the school to improve the working conditions for everyone.",
          "ko": "교원 노조는 학교에 모두를 위한 근무 조건을 개선해 달라고 요청했다.",
          "sort_order": 1
