      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The city has more than a million people.",
          "ko": "그 도시는 100만 명이 넘는 사람들이 산다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The charity raised over a million dollars, which surprised everyone at the event.",
          "ko": "그 자선단체는 100만 달러가 넘는 돈을 모금했고, 이는 행사에 참석한 모두를 놀라게 했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Millions of species inhabit the planet, yet scientists have formally described only a small fraction of that vast biological diversity.",
          "ko": "수백만의 종이 지구에 서식하지만, 과학자들은 그 방대한 생물 다양성의 극히 일부만을 공식적으로 기술했을 뿐이다.",
          "sort_order": 2
        },
        {
          "pos": "det",
          "level": 1,
          "en": "I have a million things to do today.",
          "ko": "나는 오늘 할 일이 정말 많다.",
          "sort_order": 0
        },
        {
          "pos": "det",
          "level": 2,
          "en": "She earned a million won from the part-time job that she took last summer.",
          "ko": "그녀는 지난여름에 시작한 아르바이트로 100만 원을 벌었다.",
          "sort_order": 1
        },
        {
          "pos": "det",
          "level": 3,
          "en": "The government pledged a million euros to support communities that had been devastated by the unexpected natural disaster.",
          "ko": "정부는 예상치 못한 자연재해로 황폐해진 지역사회를 지원하기 위해 100만 유로를 지원하겠다고 약속했다.",
          "sort_order": 2
        }
      ]
    },
    "1815": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "목도리, 스카프",
