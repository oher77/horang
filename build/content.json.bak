      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Hold the rail when you go down the stairs.",
          "ko": "계단을 내려갈 때 난간을 잡아라.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The new rail line connects our small town to the busy city center.",
          "ko": "새 철도 노선이 우리의 작은 마을을 번잡한 도심과 연결한다.",
