          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I feed my dog twice a day.",
          "ko": "나는 내 개에게 하루에 두 번 먹이를 준다.",
          "sort_order": 0
        },
        {
