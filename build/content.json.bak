      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "Free water is available at the front desk.",
          "ko": "프런트 데스크에서 무료 물을 이용할 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The teacher said she would be available after class if we had any questions.",
          "ko": "선생님은 질문이 있으면 수업 후에 시간이 된다고 말했다.",
          "sort_order": 1
