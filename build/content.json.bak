      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "He cut the wire with a small tool.",
          "ko": "그는 작은 도구로 그 철사를 잘랐다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The electrician found a broken wire that had caused the sudden power failure.",
          "ko": "전기 기사는 갑작스러운 정전을 일으킨 끊어진 전선을 발견했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Engineers must insulate every wire carefully, because even a tiny fault can trigger a fire in a densely packed circuit.",
          "ko": "엔지니어들은 모든 전선을 신중히 절연해야 하는데, 아주 작은 결함조차 빽빽하게 밀집된 회로에서 화재를 일으킬 수 있기 때문이다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "They will wire the new house next week.",
          "ko": "그들은 다음 주에 새 집에 배선을 할 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "My uncle promised to wire the money as soon as the bank opened in the morning.",
          "ko": "삼촌은 아침에 은행이 문을 열자마자 돈을 송금하겠다고 약속했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Technicians had to wire the entire laboratory again after discovering that the original system could not support the sensitive equipment.",
          "ko": "기술자들은 기존 시스템이 민감한 장비를 지탱할 수 없다는 것을 발견한 후 실험실 전체를 다시 배선해야 했다.",
          "sort_order": 2
        }
      ]
    },
