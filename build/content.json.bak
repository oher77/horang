      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She works in retail at a small shop.",
          "ko": "그녀는 작은 가게에서 소매업에 종사한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Online retail has grown quickly because many people now prefer to shop from home.",
          "ko": "많은 사람들이 이제 집에서 쇼핑하기를 선호하기 때문에 온라인 소매업이 빠르게 성장했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The shift toward digital retail has forced traditional stores to rethink how they attract and retain increasingly cautious consumers.",
          "ko": "디지털 소매업으로의 전환은 전통적인 상점들로 하여금 점점 신중해지는 소비자를 끌어들이고 유지하는 방법을 재고하도록 강요했다.",
          "sort_order": 2
        }
      ]
    },
    "1613": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "발음하다; 선언하다; 단언하다",
