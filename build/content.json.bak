    "1448": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "단락; 문단",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Please read the first paragraph out loud.",
          "ko": "첫 번째 단락을 소리 내어 읽어 주세요.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher explained that each paragraph should focus on a single main idea.",
          "ko": "선생님은 각 단락이 하나의 중심 생각에 집중해야 한다고 설명하셨다.",
