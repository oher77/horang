      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Good discipline helps students study every day.",
          "ko": "좋은 규율은 학생들이 매일 공부하도록 돕는다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The coach believed that discipline was more important than natural talent for young athletes.",
          "ko": "그 코치는 어린 선수들에게 재능보다 규율이 더 중요하다고 믿었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Economics is a discipline that requires both mathematical precision and a deep understanding of complex human behavior.",
          "ko": "경제학은 수학적 정밀함과 복잡한 인간 행동에 대한 깊은 이해를 모두 요구하는 학문 분야이다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Parents should discipline their children with love.",
          "ko": "부모는 사랑으로 자녀를 훈육해야 한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher tried to discipline the students who kept talking during the important lesson.",
          "ko": "그 교사는 중요한 수업 중에 계속 떠드는 학생들을 훈육하려 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Successful individuals often discipline themselves to pursue long-term goals rather than yielding to immediate temptations.",
          "ko": "성공한 사람들은 흔히 즉각적인 유혹에 굴복하기보다 장기적 목표를 추구하도록 스스로를 단련한다.",
          "sort_order": 2
        }
      ]
    },
