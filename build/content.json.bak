    "1491": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "설득하다; 납득시키다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I tried to persuade my friend to join the club.",
          "ko": "나는 친구에게 그 동아리에 가입하라고 설득하려 했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher managed to persuade the students that reading widely would improve their writing.",
          "ko": "선생님은 폭넓은 독서가 글쓰기를 향상시킬 것이라고 학생들을 설득해 냈다.",
          "sort_order": 1
