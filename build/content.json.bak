      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "He found a decent job after leaving school.",
          "ko": "그는 학교를 떠난 뒤 괜찮은 일자리를 구했다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The hotel was quite decent, and the staff treated every guest with respect.",
          "ko": "그 호텔은 꽤 괜찮았고, 직원들은 모든 손님을 존중하며 대했다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "A decent society ensures that even its poorest members can access education, health care, and a fair chance to succeed.",
          "ko": "품위 있는 사회는 가장 가난한 구성원조차 교육, 의료, 그리고 성공할 공정한 기회를 누릴 수 있도록 보장한다.",
          "sort_order": 2
        }
      ]
    },
    "2304": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "중요성; 중요함",
          "sort_order": 0
