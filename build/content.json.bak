      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "Rain seems probable, so take your umbrella today.",
          "ko": "비가 올 것 같으니 오늘 우산을 챙겨라.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "It is probable that the school will close early because a storm is coming.",
          "ko": "폭풍이 다가오고 있어서 학교가 일찍 문을 닫을 가능성이 높다.",
          "sort_order": 1
