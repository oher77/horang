    "2088": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "조약; 협정",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The two countries signed a peace treaty last year.",
          "ko": "두 나라는 작년에 평화 조약에 서명했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The treaty that both nations approved aimed to reduce trade barriers between them.",
          "ko": "두 나라가 승인한 그 조약은 그들 사이의 무역 장벽을 줄이는 것을 목표로 했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Leaders negotiated a treaty because they hoped to prevent future conflicts over shared borders.",
          "ko": "지도자들은 국경을 둘러싼 미래의 분쟁을 막기를 바랐기 때문에 조약을 협상했다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The international treaty on climate change required participating governments to cut emissions gradually, yet compliance varied widely across regions.",
          "ko": "기후 변화에 관한 그 국제 조약은 참여 정부들이 배출량을 점진적으로 줄이도록 요구했지만, 이행 정도는 지역마다 크게 달랐다.",
          "sort_order": 3
        }
      ]
    },
    "1581": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "막다; 예방하다; 방지하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Wash your hands to prevent colds.",
          "ko": "감기를 예방하려면 손을 씻어라.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The new rules were made to prevent students from cheating on exams.",
          "ko": "새 규칙은 학생들이 시험에서 부정행위를 하는 것을 막기 위해 만들어졌다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Regular exercise can prevent many diseases that harm the body over time.",
          "ko": "규칙적인 운동은 시간이 지나며 몸을 해치는 여러 질병을 예방할 수 있다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Public health policies aim to prevent the spread of infectious diseases before they overwhelm hospitals and threaten vulnerable populations.",
          "ko": "공중 보건 정책은 전염병이 병원을 압도하고 취약 계층을 위협하기 전에 그 확산을 막는 것을 목표로 한다.",
          "sort_order": 3
        }
      ]
    },
    "28": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "적응하다; 조정하다; 각색하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Animals must adapt to survive in a new place.",
          "ko": "동물은 새로운 곳에서 살아남으려면 적응해야 한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Students who quickly adapt to online classes often manage their time much better.",
          "ko": "온라인 수업에 빠르게 적응하는 학생들은 대개 시간을 훨씬 잘 관리한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Organisms that fail to adapt to shifting environmental conditions gradually decline, while flexible species thrive and expand into new territories.",
          "ko": "변화하는 환경 조건에 적응하지 못하는 생물은 점차 쇠퇴하는 반면, 유연한 종은 번성하며 새로운 영역으로 확장한다.",
          "sort_order": 2
        }
      ]
    },
    "1843": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "자아; 자신; 본모습",
          "sort_order": 0
        },
        {
          "pos": "pron",
          "meaning_ko": "자기 자신",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She drew a picture of her true self.",
          "ko": "그녀는 자신의 진짜 모습을 그림으로 그렸다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "After the long trip, he finally felt like his old self again.",
          "ko": "긴 여행 후에 그는 마침내 예전의 자기 자신으로 돌아온 느낌이 들었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Psychologists argue that our sense of self emerges gradually through countless interactions with others in society.",
          "ko": "심리학자들은 우리의 자아감이 사회에서 타인과의 무수한 상호작용을 통해 점진적으로 형성된다고 주장한다.",
          "sort_order": 2
        },
        {
          "pos": "pron",
          "level": 1,
          "en": "Please write a check payable to self.",
          "ko": "본인 앞으로 수표를 발행해 주세요.",
          "sort_order": 0
        },
        {
          "pos": "pron",
          "level": 2,
          "en": "The form asked whether the payment was made to self or to another party.",
          "ko": "그 양식은 지불이 본인에게 되었는지 아니면 다른 당사자에게 되었는지 물었다.",
          "sort_order": 1
        },
        {
          "pos": "pron",
          "level": 3,
          "en": "In certain legal documents, the term 'self' is used to indicate that a transaction concerns the signer personally rather than any third party.",
          "ko": "특정 법률 문서에서 'self'라는 용어는 거래가 제삼자가 아니라 서명자 본인과 관련됨을 나타내는 데 쓰인다.",
          "sort_order": 2
        }
      ]
    },
    "921": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "집단; 무리; 그룹",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "모으다; 분류하다; 무리 짓다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "A group of children played in the park.",
          "ko": "한 무리의 아이들이 공원에서 놀았다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Our teacher divided the class into small groups so that everyone could join the discussion.",
          "ko": "선생님은 모두가 토론에 참여할 수 있도록 반을 작은 그룹으로 나누었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Social psychologists have long studied how a person's behavior changes when he or she belongs to a large group.",
          "ko": "사회심리학자들은 사람이 큰 집단에 속했을 때 그 행동이 어떻게 변하는지를 오랫동안 연구해 왔다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Please group the books by color.",
          "ko": "책들을 색깔별로 분류하세요.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The students grouped the plants according to the shape of their leaves during the science class.",
          "ko": "학생들은 과학 수업 시간에 잎의 모양에 따라 식물들을 분류했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Analysts often group consumers by shared spending patterns in order to predict how each segment will respond to new products.",
          "ko": "분석가들은 각 집단이 신제품에 어떻게 반응할지 예측하기 위해 공통된 소비 패턴에 따라 소비자를 분류하는 경우가 많다.",
          "sort_order": 2
        }
      ]
    },
    "1122": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "칼; 나이프",
