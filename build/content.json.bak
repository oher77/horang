          "pos": "n",
          "meaning_ko": "절차; 과정; 방법; 수술",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Please follow the safety procedure before you start.",
          "ko": "시작하기 전에 안전 절차를 따르세요.",
