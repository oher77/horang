      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She paid for the shoes with her credit card.",
          "ko": "그녀는 신용카드로 신발 값을 지불했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The student earned extra credit by completing the difficult science project on time.",
          "ko": "그 학생은 어려운 과학 과제를 제때 완료해 추가 학점을 얻었다.",
