    "2315": {
      "meanings": [
        {
          "pos": "ad",
          "meaning_ko": "문자 그대로; 말 그대로; 정말로",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "ad",
          "level": 1,
          "en": "He was literally shaking with fear.",
          "ko": "그는 말 그대로 두려움에 떨고 있었다.",
          "sort_order": 0
        },
        {
          "pos": "ad",
          "level": 2,
          "en": "The word cannot be translated literally, so you must consider its cultural meaning.",
          "ko": "그 단어는 문자 그대로 번역할 수 없으므로 문화적 의미를 고려해야 한다.",
          "sort_order": 1
