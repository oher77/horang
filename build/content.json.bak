    "224": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "확실한; 특정한; 어떤",
          "sort_order": 0
        },
        {
          "pos": "pron",
          "meaning_ko": "(~of/among) 어떤 것들; 일부",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "I am certain that he will come to the party.",
          "ko": "나는 그가 파티에 올 것이라고 확신한다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Certain students who study abroad often face challenges they never expected before.",
          "ko": "해외에서 공부하는 어떤 학생들은 이전에 전혀 예상하지 못한 어려움에 자주 직면한다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Scientists cannot be entirely certain about future climate patterns, since complex systems respond to countless interacting variables over long periods.",
          "ko": "과학자들은 미래의 기후 패턴에 대해 완전히 확신할 수 없는데, 복잡한 시스템은 오랜 기간에 걸쳐 상호작용하는 무수한 변수에 반응하기 때문이다.",
          "sort_order": 2
        },
        {
          "pos": "pron",
          "level": 1,
          "en": "Certain of the books were too old to read.",
          "ko": "그 책들 중 어떤 것들은 너무 낡아서 읽을 수 없었다.",
          "sort_order": 0
        },
        {
          "pos": "pron",
          "level": 2,
          "en": "Certain of the members disagreed with the decision that the committee had just announced.",
          "ko": "회원들 중 일부는 위원회가 방금 발표한 결정에 동의하지 않았다.",
          "sort_order": 1
        },
        {
          "pos": "pron",
          "level": 3,
          "en": "Certain among the participants reported lasting benefits, whereas others noticed no measurable change despite following the same demanding routine.",
          "ko": "참가자들 중 일부는 지속적인 이점을 보고했으나, 다른 이들은 동일하고 힘든 일과를 따랐음에도 측정 가능한 변화를 느끼지 못했다.",
          "sort_order": 2
        }
      ]
    },
    "591": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "몹시 두려워하다; 무서워하다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "두려움; 공포",
          "sort_order": 1
        },
        {
          "pos": "a",
          "meaning_ko": "무서운; 두려운",
          "sort_order": 2
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I dread the test that we have tomorrow.",
          "ko": "나는 내일 있을 시험이 몹시 두렵다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many students dread public speaking because they worry about making mistakes in front of others.",
          "ko": "많은 학생들은 다른 사람들 앞에서 실수하는 것을 걱정하기 때문에 발표를 몹시 두려워한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Patients often dread the results of a medical exam, imagining outcomes far worse than what the actual diagnosis usually reveals.",
          "ko": "환자들은 종종 실제 진단이 보통 드러내는 것보다 훨씬 더 나쁜 결과를 상상하며 검사 결과를 몹시 두려워한다.",
          "sort_order": 2
        }
      ]
    },
    "1391": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "일어나다; 발생하다; 생각이 떠오르다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The accident occurred early in the morning.",
          "ko": "그 사고는 이른 아침에 일어났다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Strange noises occurred at night, which frightened the children in the house.",
          "ko": "밤에 이상한 소리가 발생했고, 그것은 집 안의 아이들을 겁먹게 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "It never occurred to the scientists that such a rare phenomenon might occur under perfectly ordinary laboratory conditions.",
          "ko": "그런 희귀한 현상이 완전히 평범한 실험실 조건에서 일어날 수도 있다는 생각이 과학자들에게는 전혀 떠오르지 않았다.",
          "sort_order": 2
        }
      ]
    },
    "2077": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "전통; 관습",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Eating rice cakes is a New Year tradition in Korea.",
          "ko": "떡을 먹는 것은 한국의 설날 전통이다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Our school keeps a tradition that older students help the new ones every spring.",
          "ko": "우리 학교는 매년 봄 선배들이 신입생을 돕는 전통을 지키고 있다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A living tradition endures not because it resists change but because each generation reinterprets its meaning for new circumstances.",
          "ko": "살아 있는 전통은 변화에 저항하기 때문이 아니라 각 세대가 새로운 상황에 맞게 그 의미를 재해석하기 때문에 지속된다.",
          "sort_order": 2
        }
      ]
    },
    "655": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "둘러싸다; 에워싸다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "주위; 근교; 환경",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Tall trees environ the small village.",
          "ko": "키 큰 나무들이 그 작은 마을을 둘러싸고 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "High stone walls environ the castle, which once protected the people inside.",
          "ko": "높은 돌담이 성을 에워싸고 있으며, 그것은 한때 안의 사람들을 보호했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Dense forests and steep mountains environ the ancient monastery, isolating it from the noise and pressures of modern civilization.",
          "ko": "울창한 숲과 가파른 산이 그 고대 수도원을 에워싸, 현대 문명의 소음과 압박으로부터 그곳을 고립시킨다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "They walked through the quiet environs of the town.",
          "ko": "그들은 마을의 조용한 근교를 걸었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The museum stands in the environs of the city, where many tourists gather each year.",
          "ko": "그 박물관은 매년 많은 관광객이 모이는 도시 근교에 자리 잡고 있다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Urban planners studied the environs of the growing metropolis, hoping to preserve green spaces while accommodating a rapidly rising population.",
          "ko": "도시 계획가들은 성장하는 대도시의 주변 지역을 연구하며, 급증하는 인구를 수용하면서도 녹지를 보존하기를 바랐다.",
          "sort_order": 2
        }
      ]
    },
    "2141": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "처녀; 동정인 사람; 초심자",
          "sort_order": 0
        },
        {
          "pos": "a",
          "meaning_ko": "처녀의; 자연 그대로의; 원시의",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She was still a virgin when she left home.",
          "ko": "그녀는 집을 떠날 때 아직 처녀였다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "In many old stories, a virgin is chosen to protect the village from harm.",
          "ko": "많은 옛이야기에서, 마을을 해악으로부터 지키기 위해 처녀가 선택된다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The novel portrays a young virgin whose innocence gradually collides with the harsh realities of the adult world.",
          "ko": "그 소설은 순수함이 어른 세계의 냉혹한 현실과 점차 충돌하는 한 젊은 처녀를 그린다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "We hiked through a virgin forest last summer.",
          "ko": "우리는 지난여름에 원시림을 하이킹했다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The explorers reached a virgin land that no human had ever touched before.",
          "ko": "탐험가들은 이전에 그 어떤 인간도 손대지 않은 자연 그대로의 땅에 도달했다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Preserving virgin ecosystems has become a central concern for scientists who study how untouched environments regulate the global climate.",
          "ko": "자연 그대로의 생태계를 보존하는 일은 손대지 않은 환경이 지구 기후를 어떻게 조절하는지 연구하는 과학자들의 핵심 관심사가 되었다.",
          "sort_order": 2
        }
      ]
    },
    "1719": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "임차하다; 임대하다; 빌리다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "집세; 임대료",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "We want to rent a car for the weekend.",
          "ko": "우리는 주말 동안 차를 빌리고 싶다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Since dorm fees rose, many students now rent small rooms near the campus.",
          "ko": "기숙사비가 올랐기 때문에 많은 학생들이 이제 캠퍼스 근처의 작은 방을 임차한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Young workers who cannot afford to buy property often choose to rent apartments in cities where housing prices keep rising steadily.",
          "ko": "부동산을 살 여유가 없는 젊은 근로자들은 주택 가격이 꾸준히 오르는 도시에서 아파트를 임차하는 것을 선택하는 경우가 많다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "The rent for this room is quite cheap.",
          "ko": "이 방의 집세는 꽤 저렴하다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Because the rent increased sharply, the small bookstore had to move to another street.",
          "ko": "임대료가 급격히 올랐기 때문에 그 작은 서점은 다른 거리로 이사해야 했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Rising rent in urban areas forces low-income families to relocate, gradually reshaping the social structure of entire neighborhoods over time.",
          "ko": "도시 지역의 오르는 임대료는 저소득 가정을 이주하게 만들어, 시간이 지나면서 동네 전체의 사회 구조를 점차 재편한다.",
          "sort_order": 2
        }
      ]
    },
    "1713": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "남다; 여전히 ~이다; 머무르다",
