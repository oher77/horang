      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The company will launch a new phone next month.",
          "ko": "그 회사는 다음 달에 새 휴대폰을 출시할 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The school launched a program that helps students who struggle with math.",
          "ko": "그 학교는 수학에 어려움을 겪는 학생들을 돕는 프로그램을 시작했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "The agency plans to launch a satellite that will monitor subtle changes in the planet's climate over decades.",
          "ko": "그 기관은 수십 년에 걸쳐 지구 기후의 미세한 변화를 관측할 위성을 발사할 계획이다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "The launch of the rocket was on the news.",
          "ko": "그 로켓의 발사가 뉴스에 나왔다.",
          "sort_order": 3
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The product launch was delayed because the marketing team needed more time.",
          "ko": "마케팅 팀이 더 많은 시간이 필요했기 때문에 제품 출시가 연기되었다.",
          "sort_order": 4
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The successful launch of the campaign depended on careful coordination among departments that had rarely worked together before.",
          "ko": "그 캠페인의 성공적인 개시는 이전에 좀처럼 협력하지 않았던 부서들 간의 세심한 조율에 달려 있었다.",
          "sort_order": 5
        }
      ]
    },
    "1301": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "모형; 모범; 모델",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "본뜨다; 모형을 만들다; 모델로 삼다",
          "sort_order": 1
        },
        {
          "pos": "a",
          "meaning_ko": "모범적인; 모형의",
          "sort_order": 2
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "He built a small model of a ship.",
          "ko": "그는 작은 배 모형을 만들었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher praised her essay as a model that other students should follow.",
          "ko": "선생님은 그녀의 에세이를 다른 학생들이 따라야 할 모범으로 칭찬했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Economists rely on simplified models to predict how markets might respond to sudden changes in policy.",
          "ko": "경제학자들은 시장이 정책의 급격한 변화에 어떻게 반응할지 예측하기 위해 단순화된 모형에 의존한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "She likes to model animals out of clay.",
          "ko": "그녀는 점토로 동물을 본떠 만드는 것을 좋아한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many children model their behavior on the adults whom they admire most.",
          "ko": "많은 아이들은 자신이 가장 존경하는 어른을 본떠 행동한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Scientists model complex climate systems on powerful computers to understand how tiny variables can influence long-term global patterns.",
          "ko": "과학자들은 작은 변수들이 어떻게 장기적인 지구적 패턴에 영향을 미치는지 이해하기 위해 강력한 컴퓨터로 복잡한 기후 시스템을 모형화한다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "He is a model student in our class.",
          "ko": "그는 우리 반에서 모범적인 학생이다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The company was praised as a model example of how to treat its workers fairly.",
          "ko": "그 회사는 근로자를 공정하게 대우하는 방법의 모범적인 사례로 칭찬받았다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "The town was presented as a model community whose sustainable practices could be adopted by other regions facing similar challenges.",
          "ko": "그 마을은 유사한 문제에 직면한 다른 지역들이 채택할 수 있는, 지속 가능한 관행을 지닌 모범적인 공동체로 소개되었다.",
          "sort_order": 2
        }
      ]
    },
    "629": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "대사관",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She went to the embassy to get a new passport.",
          "ko": "그녀는 새 여권을 받으러 대사관에 갔다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "When travelers lose their documents abroad, they should contact their embassy for help.",
          "ko": "여행자들이 해외에서 서류를 잃어버리면 도움을 받기 위해 대사관에 연락해야 한다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "During the diplomatic crisis, the embassy served as a crucial channel through which two governments quietly negotiated a peaceful settlement.",
          "ko": "외교적 위기 동안 그 대사관은 두 정부가 조용히 평화적 해결을 협상하는 중요한 통로 역할을 했다.",
          "sort_order": 2
        }
      ]
    },
    "2346": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "인식; 지각; 견해",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Our perception of color can change in different light.",
          "ko": "색에 대한 우리의 지각은 다른 빛 속에서 바뀔 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The company tried to change public perception of its products through honest advertising.",
          "ko": "그 회사는 정직한 광고를 통해 제품에 대한 대중의 인식을 바꾸려 했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Psychologists argue that our perception of reality is shaped less by raw sensory data than by prior expectations and cultural context.",
          "ko": "심리학자들은 현실에 대한 우리의 인식이 순수한 감각 자료보다 사전 기대와 문화적 맥락에 의해 더 형성된다고 주장한다.",
          "sort_order": 2
        }
      ]
    },
    "1486": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "영구적인; 영원한; 상설의",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "She finally got a permanent job at the bank.",
          "ko": "그녀는 마침내 은행에 정규직 일자리를 얻었다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The city built a permanent shelter that could protect people during heavy storms.",
          "ko": "그 도시는 거센 폭풍우 동안 사람들을 보호할 수 있는 상설 대피소를 지었다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Scientists warn that the loss of certain species may cause permanent damage to ecosystems that no policy can later reverse.",
          "ko": "과학자들은 특정 종의 소실이 어떤 정책으로도 나중에 되돌릴 수 없는 영구적인 손상을 생태계에 초래할 수 있다고 경고한다.",
          "sort_order": 2
        }
      ]
    },
    "1079": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "중간의; 중급의",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "중급자; 중간물",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "She is in the intermediate English class now.",
          "ko": "그녀는 지금 중급 영어 반에 있다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The teacher chose books at an intermediate level so that most students could follow along.",
          "ko": "선생님은 대부분의 학생이 따라올 수 있도록 중급 수준의 책을 골랐다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Between the initial reaction and the final product lie several intermediate stages that determine the overall efficiency of the process.",
          "ko": "초기 반응과 최종 산물 사이에는 전체 공정의 효율을 결정하는 여러 중간 단계가 존재한다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "He is an intermediate, not a beginner.",
          "ko": "그는 초보자가 아니라 중급자이다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The course is designed for intermediates who already know the basic rules of grammar.",
          "ko": "그 강좌는 기본 문법 규칙을 이미 아는 중급자들을 위해 설계되었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "In the chemical pathway, several unstable intermediates form briefly before the system reaches a more stable configuration.",
          "ko": "그 화학 경로에서는 계가 더 안정된 상태에 이르기 전에 여러 불안정한 중간체가 잠시 형성된다.",
          "sort_order": 2
        }
      ]
    },
    "1992": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "주제; 과목; 대상; 신하",
          "sort_order": 0
        },
        {
          "pos": "a",
          "meaning_ko": "~의 영향을 받는; ~하기 쉬운; ~을 조건으로 하는",
          "sort_order": 1
        },
        {
          "pos": "v",
          "meaning_ko": "복종시키다; 겪게 하다",
          "sort_order": 2
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Math is my favorite subject at school.",
          "ko": "수학은 내가 학교에서 가장 좋아하는 과목이다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher changed the subject when students grew bored with the lesson.",
          "ko": "학생들이 수업에 지루해하자 선생님은 주제를 바꾸었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The subject of the study was how memory reshapes past events to fit our current beliefs.",
          "ko": "그 연구의 주제는 기억이 과거 사건을 현재의 신념에 맞게 어떻게 재구성하는가였다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "All prices are subject to change without notice.",
          "ko": "모든 가격은 예고 없이 변경될 수 있다.",
          "sort_order": 3
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The plan is subject to approval by the committee that meets next week.",
          "ko": "그 계획은 다음 주에 열리는 위원회의 승인을 받아야 한다.",
          "sort_order": 4
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Coastal regions are especially subject to flooding as rising sea levels intensify seasonal storms.",
          "ko": "해안 지역은 해수면 상승이 계절성 폭풍을 강화하면서 특히 홍수에 취약하다.",
          "sort_order": 5
        },
        {
          "pos": "v",
          "level": 1,
          "en": "They should not subject animals to such tests.",
          "ko": "그들은 동물을 그런 실험에 노출시켜서는 안 된다.",
          "sort_order": 6
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The new manager subjected every report to careful review before it was published.",
          "ko": "새 관리자는 모든 보고서를 발표 전에 신중한 검토를 거치게 했다.",
          "sort_order": 7
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Authoritarian systems often subject citizens to constant surveillance in order to suppress dissent and preserve control.",
          "ko": "권위주의 체제는 반대를 억누르고 통제를 유지하기 위해 시민들을 끊임없는 감시에 시달리게 하는 경우가 많다.",
          "sort_order": 8
        }
      ]
    },
    "166": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "지루하게 하다; (구멍을) 뚫다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "지루한 사람; 따분한 것",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Long movies often bore me after an hour.",
          "ko": "긴 영화는 한 시간 후면 종종 나를 지루하게 한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher tried not to bore students, so she added games to every lesson.",
          "ko": "그 교사는 학생들을 지루하게 하지 않으려고 수업마다 게임을 추가했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Workers used a massive machine to bore a tunnel through the mountain, a task that demanded remarkable engineering precision.",
          "ko": "인부들은 거대한 기계를 사용해 산을 관통하는 터널을 뚫었는데, 이는 놀라운 공학적 정밀성을 요구하는 작업이었다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "My cousin is a real bore at parties.",
          "ko": "내 사촌은 파티에서 정말 따분한 사람이다.",
          "sort_order": 3
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Everyone thought the lecture was a bore, so few students stayed until the end.",
          "ko": "모두가 그 강의를 따분한 것으로 여겼고, 그래서 끝까지 남은 학생은 거의 없었다.",
          "sort_order": 4
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Although he was widely regarded as a bore, his patient explanations later proved invaluable to colleagues facing complex problems.",
          "ko": "비록 그는 널리 따분한 사람으로 여겨졌지만, 그의 인내심 있는 설명은 훗날 복잡한 문제에 직면한 동료들에게 매우 소중한 것으로 드러났다.",
          "sort_order": 5
        }
      ]
    },
