      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "They live in a remote village near the mountains.",
          "ko": "그들은 산 근처의 외딴 마을에 산다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Many workers now enjoy remote jobs that allow them to work from home.",
          "ko": "많은 근로자들은 이제 집에서 일할 수 있는 원격 근무를 즐긴다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Scientists rely on satellites to monitor remote regions where human access remains extremely difficult and costly.",
          "ko": "과학자들은 인간의 접근이 여전히 매우 어렵고 비용이 많이 드는 외딴 지역을 관찰하기 위해 위성에 의존한다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "Please pass me the remote for the TV.",
          "ko": "TV 리모컨 좀 건네줘.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "She couldn't find the remote, so she changed the channel by hand.",
          "ko": "그녀는 리모컨을 찾지 못해서 손으로 채널을 바꿨다.",
          "sort_order": 1
