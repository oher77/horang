      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The road has a sharp curve near the hill.",
          "ko": "그 길은 언덕 근처에 급한 커브가 있다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher drew a smooth curve on the board to show how the sales rose over time.",
          "ko": "선생님은 판매가 시간이 지나며 어떻게 올랐는지 보여주려고 칠판에 매끄러운 곡선을 그렸다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Economists often examine the demand curve to predict how consumers respond when the price of a product gradually changes.",
          "ko": "경제학자들은 상품 가격이 점진적으로 변할 때 소비자가 어떻게 반응하는지 예측하기 위해 흔히 수요 곡선을 살핀다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The river curves gently around the small village.",
          "ko": "그 강은 작은 마을을 완만하게 감돌아 흐른다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The path curved to the left, so we could not see where it finally ended.",
          "ko": "길이 왼쪽으로 휘어져서 우리는 그것이 결국 어디에서 끝나는지 볼 수 없었다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Light curves slightly as it passes near a massive object, a phenomenon that scientists use to detect distant stars.",
          "ko": "빛은 거대한 물체 근처를 지날 때 약간 휘어지는데, 이는 과학자들이 먼 별을 탐지하는 데 이용하는 현상이다.",
          "sort_order": 2
        }
      ]
    },
    "25": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "인정하다; 승인하다; (편지 등을) 받았음을 알리다",
