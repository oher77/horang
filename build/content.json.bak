      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Keep in contact with your friends after school.",
          "ko": "방과 후에도 친구들과 연락을 유지해라.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "She made useful contacts at the fair that later helped her find a job.",
          "ko": "그녀는 박람회에서 나중에 취업에 도움이 된 유용한 인맥을 만들었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Physical contact between the two objects created a small spark.",
          "ko": "두 물체 사이의 물리적 접촉이 작은 불꽃을 일으켰다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Prolonged contact with harmful chemicals can cause serious health problems that may not appear until years later.",
          "ko": "유해 화학물질과의 장기간 접촉은 수년 뒤에야 나타날 수 있는 심각한 건강 문제를 일으킬 수 있다.",
          "sort_order": 3
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Please contact me if you have any questions.",
          "ko": "질문이 있으면 저에게 연락해 주세요.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The school will contact parents whenever their children are absent without notice.",
          "ko": "학교는 학생이 통보 없이 결석할 때마다 부모에게 연락할 것이다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Scientists tried to contact the research station repeatedly, but severe weather had disrupted all communication for several days.",
          "ko": "과학자들은 연구 기지에 반복적으로 연락을 시도했지만, 극심한 날씨가 며칠 동안 모든 통신을 차단했다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "He wears contact lenses instead of glasses.",
          "ko": "그는 안경 대신 콘택트렌즈를 낀다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The company printed its contact details on every page of the brochure.",
          "ko": "그 회사는 안내 책자의 모든 페이지에 연락처 정보를 인쇄했다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Certain contact sports carry a higher risk of injury, so athletes must follow strict safety guidelines during training.",
          "ko": "특정 접촉 스포츠는 부상 위험이 더 높아서, 선수들은 훈련 중 엄격한 안전 지침을 따라야 한다.",
          "sort_order": 2
        }
      ]
    },
    "2402": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "목마른; 갈증나는; 갈망하는",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "After the long run, I was very thirsty.",
          "ko": "오래 달린 후에 나는 몹시 목이 말랐다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The students were thirsty after the game, so the coach handed out cold water.",
          "ko": "학생들은 경기 후에 목이 말라서, 코치가 차가운 물을 나눠 주었다.",
