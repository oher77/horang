        {
          "pos": "v",
          "level": 3,
          "en": "The human brain processes an enormous amount of sensory information, filtering out details that seem irrelevant to immediate survival.",
          "ko": "인간의 뇌는 엄청난 양의 감각 정보를 처리하며, 즉각적인 생존과 무관해 보이는 세부 사항들을 걸러낸다.",
          "sort_order": 2
        }
      ]
    },
    "2168": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "기지; 재치; 지혜",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Her quick wit made everyone in class laugh.",
          "ko": "그녀의 빠른 재치는 반 아이들 모두를 웃게 했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The speaker used sharp wit to explain a serious topic that could have been boring.",
          "ko": "그 연사는 자칫 지루할 수 있었던 진지한 주제를 날카로운 재치로 설명했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Great satirists rely on wit rather than anger, exposing social flaws through humor that provokes both laughter and reflection.",
          "ko": "위대한 풍자가들은 분노보다 재치에 의존하여, 웃음과 성찰을 동시에 자아내는 유머로 사회적 결함을 드러낸다.",
          "sort_order": 2
        }
      ]
    },
    "2046": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "극장; 영화관; 연극",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We went to the theater to watch a movie.",
          "ko": "우리는 영화를 보러 극장에 갔다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The old theater in our town was rebuilt so that more people could enjoy plays.",
          "ko": "우리 마을의 오래된 극장은 더 많은 사람들이 연극을 즐길 수 있도록 재건되었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Live theater offers an immediacy that film cannot replicate, since actors and audiences share the same space and respond to one another in real time.",
          "ko": "라이브 연극은 배우와 관객이 같은 공간을 공유하며 실시간으로 서로 반응하기 때문에, 영화가 재현할 수 없는 직접성을 제공한다.",
          "sort_order": 2
        }
      ]
    },
