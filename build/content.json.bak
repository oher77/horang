      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The majority of students like the new lunch menu.",
          "ko": "대다수의 학생들이 새 점심 메뉴를 좋아한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "A clear majority of voters supported the proposal that would build a new park.",
          "ko": "유권자의 명백한 과반수가 새 공원을 짓는 제안을 지지했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Although the majority of participants favored the reform, the committee delayed its decision until further evidence could be gathered.",
          "ko": "참가자의 대다수가 그 개혁을 지지했지만, 위원회는 추가 증거가 수집될 때까지 결정을 미뤘다.",
          "sort_order": 2
        }
      ]
    },
    "2372": {
      "meanings": [
