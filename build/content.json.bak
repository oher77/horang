      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The river flows slowly through the quiet village.",
          "ko": "그 강은 조용한 마을을 천천히 흘러 지나간다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Traffic flowed smoothly after the new road was opened near the school.",
          "ko": "학교 근처에 새 도로가 개통된 후 교통이 원활하게 흘러갔다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When ideas flow freely among team members, creative solutions often emerge from unexpected connections between different perspectives.",
          "ko": "팀원들 사이에서 아이디어가 자유롭게 흐를 때, 서로 다른 관점 간의 예기치 못한 연결에서 창의적인 해법이 종종 나타난다.",
          "sort_order": 2
        }
      ]
    },
    "1951": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "망치다; 상하게 하다; 버릇없게 키우다",
