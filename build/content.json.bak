      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The boy shot an arrow at the wooden target.",
          "ko": "그 소년은 나무 과녁을 향해 화살을 쏘았다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Follow the green arrow on the wall, which points to the nearest exit.",
          "ko": "가장 가까운 출구를 가리키는 벽의 초록색 화살표를 따라가라.",
