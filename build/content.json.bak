        {
          "pos": "n",
          "level": 3,
          "en": "The human heart consists of four chambers that work together to circulate blood throughout the entire body efficiently.",
          "ko": "인간의 심장은 몸 전체로 혈액을 효율적으로 순환시키기 위해 함께 작동하는 네 개의 방으로 이루어져 있다.",
          "sort_order": 2
        }
      ]
    },
    "938": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "홀; 회관; 복도",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We waited in the hall before the concert started.",
          "ko": "우리는 콘서트가 시작되기 전에 홀에서 기다렸다.",
          "sort_order": 0
