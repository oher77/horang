      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "A large rat ran across the kitchen floor.",
          "ko": "큰 쥐 한 마리가 부엌 바닥을 가로질러 달렸다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Scientists often use a rat in experiments because its body reacts much like a human's.",
          "ko": "과학자들은 쥐의 몸이 인간과 비슷하게 반응하기 때문에 실험에 자주 쥐를 사용한다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The novel portrays the informer as a rat, a figure whom the entire community despises for betraying his closest friends.",
          "ko": "그 소설은 밀고자를 쥐 같은 인물로 그리는데, 그는 가장 가까운 친구들을 배신한 탓에 온 공동체가 경멸하는 존재이다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "He promised not to rat on his friend.",
          "ko": "그는 친구를 밀고하지 않겠다고 약속했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The student refused to rat on his classmates even when the teacher pressed him for names.",
          "ko": "그 학생은 선생님이 이름을 대라고 압박했을 때조차 반 친구들을 밀고하기를 거부했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Once he agreed to rat on the corrupt officials, investigators guaranteed him protection in exchange for the confidential documents he provided.",
          "ko": "그가 부패한 관리들을 밀고하기로 동의하자, 수사관들은 그가 제공한 기밀 문서의 대가로 그에게 보호를 보장했다.",
          "sort_order": 2
        }
      ]
    },
    "545": {
