        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The old castle has a large room called the king's chamber.",
          "ko": "그 오래된 성에는 왕의 방이라 불리는 큰 방이 있다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The lawmakers gathered in the main chamber, where important debates are held every week.",
          "ko": "의원들은 매주 중요한 토론이 열리는 본회의실에 모였다.",
          "sort_order": 1
