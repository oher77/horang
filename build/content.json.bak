      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "정도; 범위; 규모",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We were surprised by the extent of the damage.",
          "ko": "우리는 피해의 규모에 놀랐다.",
