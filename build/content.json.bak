    "2406": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "교통; 운송; 수송 (수단)",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "I use public transportation to go to school.",
          "ko": "나는 학교에 갈 때 대중교통을 이용한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The city built new roads because the transportation system could not handle the traffic.",
          "ko": "교통 체계가 그 교통량을 감당할 수 없었기 때문에 그 도시는 새 도로를 건설했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Many students rely on transportation provided by the school to reach distant campuses.",
          "ko": "많은 학생들이 멀리 있는 캠퍼스에 도착하기 위해 학교가 제공하는 교통편에 의존한다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Efficient transportation networks are essential to modern economies, because they reduce the costs of moving goods and connect otherwise isolated regions.",
          "ko": "효율적인 운송망은 상품 이동 비용을 줄이고 그렇지 않으면 고립될 지역들을 연결하기 때문에 현대 경제에 필수적이다.",
          "sort_order": 3
        }
      ]
    },
    "2378": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "거주자; 주민",
