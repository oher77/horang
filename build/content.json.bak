      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The orchestra played beautiful music at the concert.",
          "ko": "오케스트라는 콘서트에서 아름다운 음악을 연주했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The school orchestra, which practices every afternoon, will perform at the spring festival.",
          "ko": "매일 오후 연습하는 학교 오케스트라는 봄 축제에서 공연할 것이다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A symphony orchestra achieves its rich sound only when dozens of musicians coordinate their timing with remarkable precision under the conductor.",
