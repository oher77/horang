    "2361": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "전례 없는; 유례없는",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "The city saw an unprecedented amount of rain last week.",
          "ko": "그 도시는 지난주에 전례 없는 양의 비를 겪었다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The company reported unprecedented profits because online sales grew faster than anyone expected.",
          "ko": "온라인 판매가 예상보다 빠르게 성장해서 그 회사는 전례 없는 수익을 보고했다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Scientists faced an unprecedented challenge as the disease spread across borders that were once considered safe.",
          "ko": "한때 안전하다고 여겨졌던 국경을 넘어 질병이 퍼지면서 과학자들은 전례 없는 도전에 직면했다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 3,
          "en": "The unprecedented pace of technological change has forced institutions to reconsider policies that once seemed permanent and universally accepted.",
          "ko": "전례 없는 기술 변화의 속도는 한때 영구적이고 보편적으로 받아들여지던 정책들을 기관들이 재고하도록 강요했다.",
          "sort_order": 3
        }
      ]
    },
    "1232": {
      "meanings": [
        {
          "pos": "phrase",
          "meaning_ko": "나와 결혼해 줘",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "phrase",
          "level": 1,
          "en": "He looked at her and said, \"Marry me.\"",
          "ko": "그는 그녀를 바라보며 \"나와 결혼해 줘\"라고 말했다.",
          "sort_order": 0
        },
        {
          "pos": "phrase",
          "level": 2,
          "en": "When he finally asked her to marry me, she smiled and hugged him tightly.",
          "ko": "그가 마침내 나와 결혼해 달라고 청하자, 그녀는 미소 지으며 그를 꼭 껴안았다.",
          "sort_order": 1
        },
        {
          "pos": "phrase",
          "level": 3,
          "en": "The words \"marry me,\" though simple, carry a profound commitment that many people spend a lifetime trying to honor faithfully.",
          "ko": "\"나와 결혼해 줘\"라는 말은 단순하지만, 많은 사람이 평생 성실히 지키려 애쓰는 깊은 약속을 담고 있다.",
          "sort_order": 2
        }
      ]
    },
