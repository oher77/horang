    "602": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "의무; 임무, 직무; 세금, 관세",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "It is your duty to keep the room clean.",
          "ko": "방을 깨끗하게 유지하는 것은 너의 의무이다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The nurse felt it was her duty to care for patients even after her shift ended.",
          "ko": "그 간호사는 근무 시간이 끝난 뒤에도 환자를 돌보는 것이 자신의 의무라고 느꼈다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Public officials have a moral duty to act transparently, since citizens entrust them with authority that must never be abused for personal gain.",
          "ko": "공직자는 투명하게 행동할 도덕적 의무가 있는데, 이는 시민들이 개인적 이익을 위해 결코 남용되어서는 안 될 권한을 그들에게 맡기기 때문이다.",
          "sort_order": 2
        }
      ]
    },
    "1966": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "응시하다; 빤히 쳐다보다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "응시; 빤히 쳐다봄",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The little boy stared at the big dog.",
          "ko": "그 어린 소년은 큰 개를 빤히 쳐다보았다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "She stared at the exam question, unable to recall the answer she had studied.",
          "ko": "그녀는 공부했던 답이 떠오르지 않아 시험 문제를 빤히 응시했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When people stare at a demanding task for too long, their focus often fades and productivity gradually declines.",
          "ko": "사람들이 어려운 과제를 너무 오래 응시하면, 종종 집중력이 흐려지고 생산성이 점차 떨어진다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "He gave me a long stare.",
          "ko": "그는 나를 오랫동안 응시했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Her cold stare made everyone in the classroom fall silent at once.",
          "ko": "그녀의 차가운 응시에 교실에 있던 모두가 즉시 조용해졌다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The interviewer's steady stare, though unsettling, was intended to test how candidates handle psychological pressure.",
          "ko": "면접관의 흔들림 없는 응시는 불편하긴 했지만, 지원자들이 심리적 압박을 어떻게 다루는지 시험하려는 의도였다.",
          "sort_order": 2
        }
      ]
    },
    "788": {
      "meanings": [
