      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I prefer tea to coffee in the morning.",
          "ko": "나는 아침에 커피보다 차를 더 좋아한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many students prefer studying in the library because it is quieter than home.",
          "ko": "많은 학생들이 집보다 조용하기 때문에 도서관에서 공부하는 것을 선호한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Consumers often prefer familiar brands over cheaper alternatives, since trust reduces the perceived risk of a poor choice.",
          "ko": "소비자들은 신뢰가 잘못된 선택의 인지된 위험을 줄여 주기 때문에 종종 더 저렴한 대안보다 익숙한 브랜드를 선호한다.",
          "sort_order": 2
        }
      ]
    },
    "1224": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "조종하다; 조작하다; 다루다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "He knows how to manipulate the small robot with a remote.",
          "ko": "그는 리모컨으로 작은 로봇을 다루는 법을 안다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Some advertisements try to manipulate people so that they buy things they do not need.",
          "ko": "어떤 광고들은 사람들이 필요 없는 물건을 사도록 조종하려 한다.",
