    "1596": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "상; 상품; 경품",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "소중히 여기다; 높이 평가하다",
          "sort_order": 1
        },
        {
          "pos": "a",
          "meaning_ko": "상을 받은; 훌륭한",
          "sort_order": 2
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She won first prize in the singing contest.",
          "ko": "그녀는 노래 대회에서 1등 상을 받았다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The students worked hard for months because the prize would cover their school trip.",
          "ko": "학생들은 그 상이 수학여행 비용을 대주기 때문에 몇 달 동안 열심히 노력했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Although the scientist had already earned a prestigious prize, she insisted that public recognition mattered far less than the pursuit of truth itself.",
          "ko": "그 과학자는 이미 권위 있는 상을 받았음에도, 대중의 인정은 진리 추구 자체보다 훨씬 덜 중요하다고 주장했다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "I prize the old watch my grandfather gave me.",
          "ko": "나는 할아버지가 주신 오래된 시계를 소중히 여긴다.",
          "sort_order": 3
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many employers prize honesty more than experience when they hire new workers.",
          "ko": "많은 고용주들은 신입 직원을 채용할 때 경험보다 정직함을 더 높이 평가한다.",
          "sort_order": 4
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Societies that prize independent thinking tend to nurture citizens who question authority and propose creative solutions to shared problems.",
          "ko": "독립적 사고를 소중히 여기는 사회는 권위에 의문을 제기하고 공동의 문제에 창의적 해법을 제안하는 시민들을 길러내는 경향이 있다.",
          "sort_order": 5
        },
        {
          "pos": "a",
          "level": 1,
          "en": "He kept a prize trophy on the shelf.",
          "ko": "그는 선반에 상을 받은 트로피를 두었다.",
          "sort_order": 6
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The farmer proudly showed us the prize pumpkin that had won at the fair.",
          "ko": "그 농부는 축제에서 상을 받은 훌륭한 호박을 자랑스럽게 우리에게 보여주었다.",
          "sort_order": 7
        },
        {
          "pos": "a",
          "level": 3,
          "en": "The gallery displayed a prize collection of paintings whose value stemmed less from their age than from the innovative techniques they revealed.",
          "ko": "그 갤러리는 그 가치가 오래됨보다 그것들이 드러낸 혁신적 기법에서 비롯된, 상을 받은 훌륭한 그림 컬렉션을 전시했다.",
          "sort_order": 8
        }
      ]
    },
    "1249": {
      "meanings": [
