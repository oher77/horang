      ]
    },
    "1459": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "승객; 탑승객",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The bus was full of tired passengers this morning.",
          "ko": "오늘 아침 버스는 지친 승객들로 가득 찼다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Every passenger who boarded the train had to show a ticket to the guard.",
          "ko": "기차에 탄 모든 승객은 검표원에게 표를 보여 주어야 했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The airline apologized to passengers whose flights were delayed by the sudden storm.",
          "ko": "항공사는 갑작스러운 폭풍으로 항공편이 지연된 승객들에게 사과했다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "As autonomous vehicles become common, passengers may no longer need any driving skills, which could fundamentally reshape our relationship with transportation.",
          "ko": "자율주행 차량이 보편화되면서 승객들은 더 이상 어떤 운전 기술도 필요하지 않을 수 있으며, 이는 교통과 우리의 관계를 근본적으로 재편할 수 있다.",
          "sort_order": 3
        }
      ]
    },
    "1954": {
      "meanings": [
