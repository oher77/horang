        },
        {
          "pos": "n",
          "meaning_ko": "개종자; 전향자",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "You can convert this room into an office.",
          "ko": "너는 이 방을 사무실로 바꿀 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The old factory was converted into a museum that many tourists now visit.",
          "ko": "그 낡은 공장은 많은 관광객이 지금 찾는 박물관으로 개조되었다.",
