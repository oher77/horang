      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She held a small coin in her palm.",
          "ko": "그녀는 작은 동전을 손바닥에 쥐고 있었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The tall palm trees along the beach swayed gently as the warm wind blew.",
          "ko": "해변을 따라 늘어선 키 큰 야자나무들이 따뜻한 바람이 불자 부드럽게 흔들렸다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Reading the lines on a person's palm has long been treated as a folk practice rather than a science with reliable predictive power.",
          "ko": "사람의 손바닥에 있는 선을 읽는 것은 오랫동안 신뢰할 만한 예측력을 지닌 과학이라기보다 민속적 관행으로 여겨져 왔다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The magician palmed the card without anyone noticing.",
          "ko": "마술사는 아무도 눈치채지 못하게 카드를 손바닥에 감췄다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "He tried to palm the extra chips while the dealer was distracted by another player.",
          "ko": "딜러가 다른 플레이어에게 정신이 팔린 사이 그는 여분의 칩을 몰래 손에 쥐려 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Skilled pickpockets can palm valuables so smoothly that victims remain unaware until they later reach for possessions that are no longer there.",
          "ko": "숙련된 소매치기는 귀중품을 매우 매끄럽게 손안에 감출 수 있어서, 피해자들은 나중에 더 이상 없는 소지품을 찾을 때까지 알아채지 못한다.",
          "sort_order": 2
        }
      ]
    },
    "2380": {
