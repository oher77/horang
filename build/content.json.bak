        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She ate a sweet pear after lunch.",
          "ko": "그녀는 점심 후에 달콤한 배 하나를 먹었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The market sells fresh pears that farmers pick from the orchard every autumn.",
          "ko": "그 시장은 농부들이 매년 가을 과수원에서 따오는 신선한 배를 판다.",
