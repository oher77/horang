        {
          "pos": "v",
          "level": 2,
          "en": "The teacher acknowledged that the exam had been harder than she expected.",
          "ko": "선생님은 그 시험이 자신이 예상했던 것보다 어려웠다고 인정했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many students failed to acknowledge the help their classmates had quietly offered them.",
          "ko": "많은 학생들이 급우들이 조용히 베푼 도움을 인정하지 못했다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Scientists must acknowledge the limitations of their data before drawing conclusions that could influence public policy.",
          "ko": "과학자들은 공공 정책에 영향을 줄 수 있는 결론을 내리기 전에 자기 데이터의 한계를 인정해야 한다.",
          "sort_order": 3
        }
      ]
    },
    "484": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "방어하다; 지키다; 변호하다",
