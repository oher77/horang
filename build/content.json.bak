        {
          "pos": "v",
          "level": 2,
          "en": "The ship was ready to sail as soon as the storm that had blocked the port passed.",
          "ko": "항구를 막았던 폭풍이 지나가자마자 그 배는 출항할 준비가 되었다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Early explorers dared to sail into uncharted waters, trusting only the stars and their imperfect maps to guide them home.",
          "ko": "초기 탐험가들은 오직 별과 불완전한 지도만을 믿고 미지의 바다로 감히 항해해 나갔다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "The white sail moved slowly in the wind.",
          "ko": "흰 돛이 바람 속에서 천천히 움직였다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The sailors raised the sail carefully so that the boat could catch the strong afternoon wind.",
          "ko": "선원들은 배가 강한 오후 바람을 받을 수 있도록 조심스럽게 돛을 올렸다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The design of a triangular sail allowed vessels to advance against the wind, transforming long-distance trade across ancient seas.",
          "ko": "삼각형 돛의 설계는 배가 바람을 거슬러 나아갈 수 있게 하여 고대 바다를 가로지르는 장거리 무역을 변화시켰다.",
          "sort_order": 2
        }
      ]
    },
    "674": {
      "meanings": [
