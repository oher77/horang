      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My neighbour often helps me carry the heavy bags.",
          "ko": "내 이웃은 종종 무거운 가방 옮기는 것을 도와준다.",
          "sort_order": 0
