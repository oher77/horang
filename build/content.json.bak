      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The teacher will convene the class after lunch.",
          "ko": "선생님은 점심 후에 학급을 소집할 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The principal decided to convene a meeting because the students raised serious concerns.",
          "ko": "교장은 학생들이 심각한 우려를 제기했기 때문에 회의를 소집하기로 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When a global crisis threatens public health, world leaders often convene to coordinate policies that individual nations cannot manage alone.",
          "ko": "세계적 위기가 공중 보건을 위협할 때, 세계 지도자들은 개별 국가가 홀로 감당할 수 없는 정책을 조율하기 위해 종종 모인다.",
          "sort_order": 2
        }
      ]
    },
    "1462": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "과거; 지난날",
