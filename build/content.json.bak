      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "He got a patent for his new invention.",
          "ko": "그는 자신의 새 발명품에 대한 특허를 받았다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The company applied for a patent to protect the technology that engineers had developed.",
          "ko": "그 회사는 기술자들이 개발한 기술을 보호하기 위해 특허를 신청했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A patent grants an inventor exclusive rights for a limited period, encouraging innovation while eventually releasing knowledge into the public domain.",
          "ko": "특허는 발명가에게 제한된 기간 동안 독점적 권리를 부여하여 혁신을 장려하는 동시에 결국 지식을 공공 영역으로 개방한다.",
          "sort_order": 2
        }
      ]
    },
    "619": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "선출하다; 선택하다",
          "sort_order": 0
        },
        {
          "pos": "a",
          "meaning_ko": "당선된; 선출된",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "We will elect a new class leader today.",
          "ko": "우리는 오늘 새 반장을 선출할 것이다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Citizens elect their representatives so that public opinions can be heard in government.",
          "ko": "시민들은 국정에 여론이 반영될 수 있도록 자신들의 대표를 선출한다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When voters elect leaders based on short-term promises, they often overlook the long-term consequences that shape a nation's future.",
          "ko": "유권자들이 단기적인 공약을 근거로 지도자를 선출할 때, 그들은 국가의 미래를 형성하는 장기적 결과를 종종 간과한다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "The president elect gave a short speech.",
          "ko": "당선된 대통령이 짧은 연설을 했다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The mayor elect promised to improve public transport before he officially took office.",
          "ko": "당선된 시장은 공식적으로 취임하기 전에 대중교통을 개선하겠다고 약속했다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "The governor elect faced enormous pressure to fulfill campaign pledges that had persuaded many hesitant voters to support him.",
          "ko": "당선된 주지사는 많은 망설이던 유권자들이 그를 지지하도록 설득했던 선거 공약을 이행해야 한다는 엄청난 압박에 직면했다.",
          "sort_order": 2
        }
      ]
    },
    "2213": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "결정적인; 확실한",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "We still have no conclusive answer to the question.",
          "ko": "우리는 아직 그 질문에 대한 확실한 답이 없다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The police could not arrest him because there was no conclusive evidence linking him to the crime.",
          "ko": "그를 범죄와 연결하는 결정적인 증거가 없었기 때문에 경찰은 그를 체포할 수 없었다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Although the survey suggested a trend, scientists warned that a single study is rarely conclusive without further replication and peer review.",
          "ko": "그 설문이 어떤 경향을 시사하기는 했지만, 과학자들은 추가적인 재현과 동료 검토 없이는 단일 연구가 결정적인 경우가 드물다고 경고했다.",
          "sort_order": 2
        }
      ]
    },
    "189": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "정육점 주인; 도살업자",
