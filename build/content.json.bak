    "2123": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "사라지다; 없어지다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The cat seemed to vanish behind the tall fence.",
          "ko": "그 고양이는 높은 울타리 뒤로 사라진 것 같았다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The old traditions began to vanish as the younger generation moved to the city.",
          "ko": "젊은 세대가 도시로 이주하면서 오래된 전통들이 사라지기 시작했다.",
