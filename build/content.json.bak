          "sort_order": 2
        }
      ]
    },
    "2217": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "건설; 공사; 건축물; 구성",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The construction of the new bridge took two years.",
          "ko": "새 다리의 건설은 2년이 걸렸다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The construction near our school caused noise that made it hard to focus in class.",
          "ko": "학교 근처의 공사는 소음을 일으켜 수업에 집중하기 어렵게 했다.",
