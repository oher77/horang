        {
          "pos": "v",
          "meaning_ko": "조경하다; 정원을 꾸미다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We enjoyed the beautiful landscape from the hill.",
          "ko": "우리는 언덕에서 아름다운 풍경을 즐겼다.",
          "sort_order": 0
