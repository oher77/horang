      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The children rolled down the grassy slope.",
          "ko": "아이들은 풀이 난 비탈을 굴러 내려갔다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The steep slope of the mountain made the hiking trail quite dangerous for beginners.",
          "ko": "산의 가파른 경사는 그 등산로를 초보자에게 상당히 위험하게 만들었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Engineers carefully measured the slope of the land before designing a drainage system that could prevent seasonal flooding.",
          "ko": "기술자들은 계절성 홍수를 막을 수 있는 배수 시스템을 설계하기 전에 지형의 기울기를 신중하게 측정했다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The roof slopes down toward the back of the house.",
          "ko": "지붕은 집 뒤쪽을 향해 경사져 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The road slopes gently upward as it approaches the small village on the hill.",
          "ko": "그 길은 언덕 위 작은 마을에 다가가면서 완만하게 위로 경사진다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "The landscape slopes gradually toward the coast, allowing rainwater to drain naturally into the sea without causing erosion.",
          "ko": "그 지형은 해안을 향해 점차 경사져 있어, 침식을 일으키지 않고 빗물이 자연스럽게 바다로 흘러들게 한다.",
          "sort_order": 2
        }
      ]
    },
    "1091": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "조사하다; 수사하다; 연구하다",
