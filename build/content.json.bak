      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Milk gives us a mineral called calcium.",
          "ko": "우유는 우리에게 칼슘이라는 무기질을 준다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The country exports many minerals that are used to make phones and computers.",
          "ko": "그 나라는 휴대폰과 컴퓨터를 만드는 데 쓰이는 많은 광물을 수출한다.",
