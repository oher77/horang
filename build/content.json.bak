    "951": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "가혹한; 혹독한; 거친",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "The winter was very harsh and cold this year.",
          "ko": "올해 겨울은 매우 혹독하고 추웠다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The teacher's harsh words made the students feel nervous during the class.",
          "ko": "선생님의 가혹한 말은 수업 중에 학생들을 긴장하게 만들었다.",
