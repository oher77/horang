    "436": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "잔인한; 잔혹한; 가혹한",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "It is cruel to leave a small dog alone all day.",
          "ko": "작은 개를 하루 종일 혼자 두는 것은 잔인하다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The teacher explained why cruel words can hurt classmates more than physical pain.",
          "ko": "선생님은 잔인한 말이 신체적 고통보다 급우들에게 더 상처를 줄 수 있는 이유를 설명했다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "History shows that cruel policies imposed without regard for human dignity often provoke lasting resistance among ordinary citizens.",
          "ko": "역사는 인간의 존엄을 무시한 채 강요된 가혹한 정책이 흔히 평범한 시민들 사이에서 지속적인 저항을 불러일으킨다는 것을 보여 준다.",
          "sort_order": 2
        }
      ]
    },
    "837": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "우정; 교우 관계",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Their friendship began on the first day of school.",
          "ko": "그들의 우정은 개학 첫날에 시작되었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "A true friendship grows stronger when both people share their honest feelings.",
          "ko": "진정한 우정은 두 사람이 솔직한 감정을 나눌 때 더 강해진다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Psychologists suggest that a lasting friendship depends less on shared interests than on the ability to trust and support each other over time.",
          "ko": "심리학자들은 지속적인 우정이 공통 관심사보다는 시간이 지나도 서로를 신뢰하고 지지하는 능력에 더 좌우된다고 말한다.",
          "sort_order": 2
        }
      ]
    },
    "2278": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "유명한; 명성 있는",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "This city is famous for its beautiful beaches.",
          "ko": "이 도시는 아름다운 해변으로 유명하다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The writer became famous after her first novel was translated into many languages.",
          "ko": "그 작가는 첫 소설이 여러 언어로 번역된 후에 유명해졌다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Many artists who are famous today were largely ignored during their lifetimes, gaining recognition only after their deaths.",
          "ko": "오늘날 유명한 많은 예술가들은 생전에는 대체로 무시당했고, 사후에야 인정을 받았다.",
          "sort_order": 2
        }
      ]
    },
    "953": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "싫어하다; 미워하다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "증오; 혐오",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I hate rainy days because I can't play outside.",
          "ko": "나는 밖에서 놀 수 없어서 비 오는 날을 싫어한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Many students hate exams, but they know that regular tests help them learn.",
          "ko": "많은 학생이 시험을 싫어하지만, 정기적인 시험이 학습에 도움이 된다는 것을 안다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "People often hate what they fail to understand, so exposure to unfamiliar cultures can gradually reduce such irrational hostility.",
          "ko": "사람들은 흔히 이해하지 못하는 것을 싫어하므로, 낯선 문화에 대한 접촉은 그러한 비합리적 적대감을 점차 줄일 수 있다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "His eyes were full of hate.",
          "ko": "그의 눈은 증오로 가득 차 있었다.",
          "sort_order": 3
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher warned that hate between classmates can spread quickly if it is ignored.",
          "ko": "선생님은 반 친구들 사이의 증오가 방치되면 빠르게 퍼질 수 있다고 경고했다.",
          "sort_order": 4
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Online platforms have amplified expressions of hate, prompting societies to debate how free speech should be balanced against public safety.",
          "ko": "온라인 플랫폼은 증오의 표현을 증폭시켰고, 이는 표현의 자유가 공공 안전과 어떻게 균형을 이루어야 하는지에 대한 사회적 논쟁을 촉발했다.",
          "sort_order": 5
        }
      ]
    },
