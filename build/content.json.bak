      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We did a fun science test in the laboratory.",
          "ko": "우리는 실험실에서 재미있는 과학 실험을 했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Students must wear safety goggles whenever they enter the chemistry laboratory.",
          "ko": "학생들은 화학 실험실에 들어갈 때마다 반드시 보안경을 착용해야 한다.",
          "sort_order": 1
