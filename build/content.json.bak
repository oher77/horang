    "1048": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "여관; 여인숙",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We stayed at a small inn near the lake.",
          "ko": "우리는 호수 근처의 작은 여관에 묵었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The old inn, which had welcomed travelers for centuries, still served warm meals to guests.",
          "ko": "수 세기 동안 여행자들을 맞이해 온 그 오래된 여관은 여전히 손님들에게 따뜻한 식사를 제공했다.",
