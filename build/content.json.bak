        },
        {
          "pos": "v",
          "level": 3,
          "en": "Scientists must be prepared to defend their conclusions against criticism, especially when the data challenge widely accepted theories.",
          "ko": "과학자들은 특히 그 데이터가 널리 받아들여진 이론에 도전할 때, 비판에 맞서 자신의 결론을 옹호할 준비가 되어 있어야 한다.",
          "sort_order": 2
        }
      ]
    },
    "2047": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "이론; 학설; 견해",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "He has a simple theory about why people are late.",
          "ko": "그는 사람들이 늦는 이유에 대한 간단한 이론을 가지고 있다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher explained a theory that connects music and improved memory in students.",
          "ko": "선생님은 음악과 학생들의 향상된 기억력을 연결하는 이론을 설명하셨다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A scientific theory gains credibility only when its predictions are repeatedly confirmed by independent experiments across different research settings.",
          "ko": "과학 이론은 그 예측이 다양한 연구 환경의 독립적인 실험들에 의해 반복적으로 확인될 때에만 신뢰성을 얻는다.",
          "sort_order": 2
        }
      ]
    },
    "2271": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "시험; 검사; 조사",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "I studied hard for my English examination.",
          "ko": "나는 영어 시험을 위해 열심히 공부했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The doctor gave her a careful examination before deciding which treatment she needed.",
          "ko": "의사는 그녀에게 어떤 치료가 필요한지 결정하기 전에 세심한 검사를 했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "A close examination of the data revealed patterns that the students had previously overlooked.",
          "ko": "자료를 면밀히 조사하자 학생들이 이전에 간과했던 패턴이 드러났다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A rigorous examination of historical evidence often forces scholars to revise assumptions that had long been accepted without serious question.",
          "ko": "역사적 증거에 대한 엄밀한 조사는 종종 학자들에게 오랫동안 진지한 의문 없이 받아들여진 가정을 수정하도록 강요한다.",
          "sort_order": 3
        }
      ]
    },
