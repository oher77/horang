      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My mom baked a warm apple pie for dessert.",
          "ko": "엄마는 후식으로 따뜻한 사과 파이를 구우셨다.",
          "sort_order": 0
        },
        {
