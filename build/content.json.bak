    "841": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "서리; 결빙",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "서리로 덮다; 성에가 끼다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "There was white frost on the grass this morning.",
          "ko": "오늘 아침 풀밭에 하얀 서리가 내렸다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The farmers worried about the early frost that could damage their young crops.",
          "ko": "농부들은 어린 작물을 해칠 수 있는 이른 서리를 걱정했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "An unexpected autumn frost can devastate entire vineyards, since delicate grapes are highly sensitive to sudden drops in temperature.",
          "ko": "예상치 못한 가을 서리는 포도밭 전체를 황폐하게 만들 수 있는데, 연약한 포도가 갑작스러운 기온 하락에 매우 민감하기 때문이다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Ice began to frost the cold window.",
          "ko": "얼음이 차가운 창문에 성에를 끼기 시작했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "By dawn the freezing wind had frosted every branch in the quiet garden.",
          "ko": "동틀 무렵 차가운 바람이 고요한 정원의 모든 가지에 서리를 덮어 놓았다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "As the temperature plunged overnight, thin layers of ice frosted the metal railings, forming intricate crystalline patterns by morning.",
          "ko": "밤새 기온이 급락하면서 얇은 얼음층이 금속 난간을 서리로 덮어, 아침 무렵 정교한 결정 무늬를 이루었다.",
          "sort_order": 2
        }
      ]
    },
    "1401": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "오페라; 가극",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My mother loves to watch an opera on weekends.",
          "ko": "우리 어머니는 주말에 오페라 보는 것을 좋아하신다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The singer who won the prize will perform in a famous opera next month.",
          "ko": "그 상을 받은 가수는 다음 달에 유명한 오페라에서 공연할 것이다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Although opera combines music, drama, and visual art, many young people still regard it as an outdated and inaccessible form of entertainment.",
          "ko": "오페라는 음악, 연극, 시각 예술을 결합하지만, 많은 젊은이들은 여전히 그것을 시대에 뒤떨어지고 다가가기 어려운 오락 형태로 여긴다.",
          "sort_order": 2
        }
      ]
    },
    "1106": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "가입하다; 참여하다; 연결하다; 합치다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "연결 부분; 접합점",
