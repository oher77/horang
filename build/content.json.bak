          "sort_order": 2
        }
      ]
    },
    "1902": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "동시의; 동시에 일어나는",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "The two players made a simultaneous move in the game.",
          "ko": "두 선수는 게임에서 동시에 같은 동작을 했다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The teacher praised the simultaneous efforts of students who worked on the project together.",
          "ko": "선생님은 그 프로젝트를 함께 진행한 학생들의 동시적인 노력을 칭찬했다.",
