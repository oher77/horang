        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "I take a shower every morning before school.",
          "ko": "나는 매일 아침 학교 가기 전에 샤워를 한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "A sudden shower began to fall while we were walking home from the library.",
          "ko": "우리가 도서관에서 집으로 걸어오는 동안 갑작스러운 소나기가 내리기 시작했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The comet produced a spectacular shower of meteors that observers across the country described as unforgettable.",
          "ko": "그 혜성은 전국의 관측자들이 잊을 수 없다고 묘사한 장관을 이루는 유성우를 만들어 냈다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "She likes to shower after playing sports.",
          "ko": "그녀는 운동을 한 후에 샤워하는 것을 좋아한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The fans showered the winning team with cheers as they entered the stadium.",
          "ko": "팬들은 우승 팀이 경기장에 들어서자 환호를 쏟아부었다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Grateful parents often shower their children with praise, yet psychologists warn that excessive flattery may weaken genuine motivation.",
          "ko": "고마워하는 부모들은 흔히 아이들에게 칭찬을 쏟아붓지만, 심리학자들은 지나친 아첨이 진정한 동기를 약화시킬 수 있다고 경고한다.",
          "sort_order": 2
        }
      ]
    },
    "869": {
      "meanings": [
