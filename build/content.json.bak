    "2045": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "영토; 영역; 지역",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The lion protects its own territory from other animals.",
          "ko": "사자는 다른 동물들로부터 자신의 영역을 지킨다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The two nations argued for years over the small territory that lay between their borders.",
          "ko": "두 국가는 국경 사이에 놓인 작은 영토를 두고 여러 해 동안 다투었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Exploring unfamiliar intellectual territory often requires scholars to abandon assumptions that once seemed unquestionably true.",
          "ko": "낯선 지적 영역을 탐구하는 일은 흔히 학자들에게 한때 의심할 여지 없이 참으로 보였던 가정들을 버릴 것을 요구한다.",
          "sort_order": 2
        }
      ]
    },
    "476": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "갑판; (카드) 한 벌; 데크",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "장식하다; 꾸미다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We stood on the deck and looked at the sea.",
          "ko": "우리는 갑판에 서서 바다를 바라보았다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "He shuffled the deck of cards before the game so that no one could cheat.",
          "ko": "그는 아무도 속일 수 없도록 게임 전에 카드 한 벌을 섞었다.",
