      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "She gave me a sweet biscuit with my tea.",
          "ko": "그녀는 차와 함께 달콤한 비스킷을 주었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The bakery near our school sells biscuits that many students buy after class.",
          "ko": "우리 학교 근처 빵집은 많은 학생들이 방과 후에 사는 비스킷을 판다.",
