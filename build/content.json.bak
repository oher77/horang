    "2328": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "부정적인; 나쁜; 음성의",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "부정; 음성; (사진의) 음화",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "She had a negative feeling about the new plan.",
          "ko": "그녀는 새 계획에 대해 부정적인 느낌을 받았다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Too much negative news online can affect how teenagers see their own future.",
          "ko": "온라인상의 너무 많은 부정적인 뉴스는 청소년이 자신의 미래를 보는 방식에 영향을 줄 수 있다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Chronic stress often produces negative effects on both cognitive performance and emotional stability, according to recent psychological studies.",
          "ko": "최근 심리학 연구에 따르면 만성적인 스트레스는 인지 수행과 정서적 안정 모두에 부정적인 영향을 미치는 경우가 많다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "Try to focus on the good things, not the negatives.",
          "ko": "부정적인 것 말고 좋은 것에 집중하려고 노력해라.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The doctor said the test result was a negative, which relieved the worried family.",
          "ko": "의사는 검사 결과가 음성이라고 말했고, 이는 걱정하던 가족을 안심시켰다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "When weighing a policy, wise leaders carefully balance its potential positives against the negatives that may emerge over time.",
          "ko": "정책을 저울질할 때 현명한 지도자들은 잠재적 이점과 시간이 지나며 나타날 수 있는 부정적 측면을 신중히 견준다.",
          "sort_order": 2
        }
      ]
    },
    "880": {
      "meanings": [
