          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher hired a new assistant who could organize the classroom materials quickly.",
          "ko": "그 교사는 교실 자료를 빠르게 정리할 수 있는 새 보조원을 고용했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A skilled research assistant not only collects reliable data but also interprets subtle patterns that the lead scientist might overlook.",
          "ko": "숙련된 연구 조수는 신뢰할 수 있는 자료를 수집할 뿐만 아니라 수석 과학자가 놓칠 수 있는 미묘한 패턴도 해석한다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "She works as an assistant manager at the store.",
          "ko": "그녀는 그 가게에서 부매니저로 일한다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The company promoted him to an assistant director because he handled problems well.",
          "ko": "그 회사는 그가 문제를 잘 처리했기 때문에 그를 부이사로 승진시켰다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "An assistant professor is generally expected to balance teaching duties with independent research that advances the field.",
          "ko": "조교수는 일반적으로 강의 업무와 그 분야를 발전시키는 독립적인 연구를 균형 있게 수행할 것으로 기대된다.",
          "sort_order": 2
        }
      ]
    },
