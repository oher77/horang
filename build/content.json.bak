    "1202": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "혼자의; 외로운; 단 하나의",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "A lone bird sat on the wire.",
          "ko": "한 마리 새가 홀로 전선에 앉아 있었다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The lone traveler walked through the empty station, hoping to catch the last train home.",
          "ko": "그 외로운 여행자는 집으로 가는 마지막 기차를 타기를 바라며 텅 빈 역을 걸어갔다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "A lone voice of dissent can gradually reshape public opinion, especially when it appeals to reason rather than mere emotion.",
          "ko": "단 하나의 반대 목소리도, 특히 단순한 감정이 아니라 이성에 호소할 때, 점차 여론을 바꿀 수 있다.",
          "sort_order": 2
        }
      ]
    },
    "400": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "기침하다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "기침",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "She began to cough loudly during the class.",
          "ko": "그녀는 수업 중에 크게 기침하기 시작했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The doctor told me to cover my mouth whenever I cough in public.",
          "ko": "의사는 공공장소에서 기침할 때마다 입을 가리라고 내게 말했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Patients who cough persistently for weeks are advised to seek medical attention, since the symptom may signal a deeper respiratory problem.",
          "ko": "몇 주 동안 계속 기침하는 환자들은 진료를 받도록 권고되는데, 그 증상이 더 심각한 호흡기 질환을 나타낼 수 있기 때문이다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "My little brother has a bad cough today.",
          "ko": "내 남동생은 오늘 심한 기침을 한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The medicine that the pharmacist gave me quickly eased my dry cough.",
          "ko": "약사가 준 약은 나의 마른기침을 빠르게 완화해 주었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A chronic cough that lasts more than eight weeks often prompts physicians to investigate underlying conditions such as allergies or infections.",
          "ko": "8주 이상 지속되는 만성 기침은 흔히 의사가 알레르기나 감염 같은 근본 질환을 조사하도록 만든다.",
          "sort_order": 2
        }
      ]
    },
    "1958": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "정사각형; 광장",
          "sort_order": 0
        },
        {
          "pos": "a",
          "meaning_ko": "정사각형의; 공정한",
          "sort_order": 1
        },
        {
          "pos": "v",
          "meaning_ko": "제곱하다; 정사각형으로 만들다",
          "sort_order": 2
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Draw a small square on the paper.",
          "ko": "종이에 작은 정사각형을 그려라.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "We met our friends in the town square, where a small market was open.",
          "ko": "우리는 작은 시장이 열린 마을 광장에서 친구들을 만났다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The historic square, surrounded by old buildings, has long served as a place where citizens gather to share ideas.",
          "ko": "오래된 건물들로 둘러싸인 그 역사적인 광장은 오랫동안 시민들이 모여 생각을 나누는 장소로 기능해 왔다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "The table has a square top.",
          "ko": "그 탁자는 상판이 정사각형이다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "He always tries to be square with everyone, even when it is hard.",
          "ko": "그는 힘들 때조차 항상 모두에게 공정하려고 노력한다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "A truly square deal requires that both parties share the risks and rewards on equal and transparent terms.",
          "ko": "진정으로 공정한 거래는 양측이 동등하고 투명한 조건으로 위험과 보상을 나누는 것을 요구한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "You square a number by multiplying it by itself.",
          "ko": "어떤 수에 그 자신을 곱하면 그 수를 제곱하게 된다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The carpenter squared the boards carefully so that the frame would fit together.",
          "ko": "목수는 틀이 잘 맞도록 판자들을 조심스럽게 직각으로 다듬었다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Scientists often struggle to square new experimental data with theories that have been widely accepted for decades.",
          "ko": "과학자들은 수십 년간 널리 받아들여진 이론과 새로운 실험 데이터를 일치시키느라 종종 고심한다.",
          "sort_order": 2
        }
      ]
    },
    "382": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "설득하다; 납득시키다; 확신시키다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I tried to convince my friend to join the club.",
          "ko": "나는 친구에게 그 동아리에 가입하라고 설득하려 했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher used clear examples to convince the students that reading daily improves writing.",
          "ko": "선생님은 매일 읽는 것이 글쓰기를 향상시킨다는 것을 학생들에게 납득시키기 위해 명확한 예시를 사용했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "To convince skeptical policymakers, the scientists presented long-term data showing that small behavioral changes can significantly reduce urban energy consumption.",
          "ko": "회의적인 정책 입안자들을 설득하기 위해, 과학자들은 작은 행동 변화가 도시의 에너지 소비를 크게 줄일 수 있음을 보여주는 장기 데이터를 제시했다.",
          "sort_order": 2
        }
      ]
    },
    "706": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "실험; 시도",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "실험하다; 시도하다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "We did a fun experiment in science class today.",
          "ko": "우리는 오늘 과학 시간에 재미있는 실험을 했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The students designed an experiment to find out which plant grows fastest.",
          "ko": "학생들은 어떤 식물이 가장 빨리 자라는지 알아내기 위해 실험을 설계했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher explained that a careful experiment can reveal patterns we might otherwise miss.",
          "ko": "선생님은 신중한 실험이 우리가 놓칠 수도 있는 패턴을 드러낼 수 있다고 설명했다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A well-designed experiment controls variables so that researchers can attribute any observed change to a single, specific cause.",
          "ko": "잘 설계된 실험은 변인을 통제하여 연구자들이 관찰된 변화를 하나의 특정한 원인에 귀속시킬 수 있게 한다.",
          "sort_order": 3
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The children like to experiment with paint and colors.",
          "ko": "아이들은 물감과 색으로 실험하는 것을 좋아한다.",
          "sort_order": 0
        },
        {
