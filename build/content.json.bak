      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The defendant sat quietly in the small courtroom.",
          "ko": "피고인은 작은 법정에 조용히 앉아 있었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The lawyer argued that the defendant had no clear motive for the crime.",
          "ko": "변호사는 피고인에게 범행의 뚜렷한 동기가 없다고 주장했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The jury must presume that the defendant is innocent until the prosecution proves guilt beyond a reasonable doubt.",
          "ko": "배심원단은 검찰이 합리적 의심을 넘어 유죄를 입증하기 전까지 피고인이 무죄라고 추정해야 한다.",
          "sort_order": 2
        }
      ]
    },
    "1887": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "외치다; 소리치다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "외침; 고함",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The boy began to shout when he saw his friend.",
          "ko": "그 소년은 친구를 보고 소리치기 시작했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The coach had to shout loudly so that every player could hear his instructions.",
          "ko": "코치는 모든 선수가 지시를 들을 수 있도록 크게 외쳐야 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When people shout in anger, they often say things they later regret, since strong emotions can override careful reasoning.",
          "ko": "사람들이 화가 나서 소리칠 때, 강한 감정이 신중한 판단을 압도할 수 있기에 나중에 후회할 말을 종종 한다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "I heard a loud shout from the playground.",
          "ko": "나는 놀이터에서 나는 큰 외침을 들었다.",
          "sort_order": 3
        },
        {
          "pos": "n",
          "level": 2,
          "en": "A sudden shout from the back of the room made everyone turn around at once.",
          "ko": "방 뒤쪽에서 나온 갑작스러운 고함에 모두가 한꺼번에 돌아보았다.",
          "sort_order": 4
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The rescuers listened carefully for any faint shout that might reveal where the trapped hikers were hidden beneath the snow.",
          "ko": "구조대원들은 갇힌 등산객들이 눈 밑 어디에 있는지 알려줄 수 있는 희미한 외침이라도 있는지 주의 깊게 귀를 기울였다.",
          "sort_order": 5
        }
      ]
    },
    "1567": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "임신한; (의미가) 가득 찬",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "She is pregnant and expects a baby in spring.",
          "ko": "그녀는 임신 중이며 봄에 아기를 낳을 예정이다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "When a woman is pregnant, doctors advise her to eat healthy food and rest often.",
          "ko": "여성이 임신했을 때 의사들은 건강한 음식을 먹고 자주 쉬라고 조언한다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The silence after his question was pregnant with tension that everyone in the room could feel.",
          "ko": "그의 질문 뒤에 이어진 침묵은 방 안의 모두가 느낄 수 있는 긴장으로 가득 차 있었다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Nutritional research suggests that a pregnant woman's diet can subtly shape the long-term metabolic health of her child.",
          "ko": "영양학 연구는 임신한 여성의 식단이 아이의 장기적 대사 건강을 미묘하게 형성할 수 있음을 시사한다.",
          "sort_order": 3
        }
      ]
    },
    "1199": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "잠그다; 고정시키다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "자물쇠; 잠금장치",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Please lock the door before you leave.",
          "ko": "나가기 전에 문을 잠가 주세요.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "She always locks her bike to the fence so that no one can steal it.",
          "ko": "그녀는 아무도 훔쳐 가지 못하도록 항상 자전거를 울타리에 자물쇠로 채운다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "When people lock themselves into rigid opinions, they often fail to notice the evidence that quietly contradicts their beliefs.",
          "ko": "사람들이 경직된 견해에 스스로를 가두면, 자신의 믿음을 조용히 반박하는 증거를 알아차리지 못하는 경우가 많다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "The lock on the gate was broken.",
          "ko": "대문의 자물쇠가 고장 나 있었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The museum installed a new lock after several valuable items had gone missing.",
          "ko": "박물관은 귀중품 몇 점이 사라진 뒤 새 잠금장치를 설치했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Modern digital locks rely on encrypted codes, yet experts warn that no security system remains entirely immune to determined attackers.",
          "ko": "현대의 디지털 잠금장치는 암호화된 코드에 의존하지만, 전문가들은 어떤 보안 체계도 집요한 공격자로부터 완전히 안전하지는 않다고 경고한다.",
          "sort_order": 2
        }
      ]
    },
    "657": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "동등한; 같은; 평등한",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "~와 같다; 필적하다",
          "sort_order": 1
        },
        {
          "pos": "n",
          "meaning_ko": "동등한 것; 대등한 사람",
          "sort_order": 2
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "Cut the cake into four equal pieces for us.",
          "ko": "우리를 위해 케이크를 똑같은 네 조각으로 잘라라.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The teacher believes that every student should have equal chances to succeed.",
          "ko": "그 교사는 모든 학생이 성공할 동등한 기회를 가져야 한다고 믿는다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "A just society strives to guarantee equal access to education, regardless of the social class into which one happens to be born.",
          "ko": "정의로운 사회는 우연히 태어난 사회 계층과 관계없이 교육에 대한 동등한 접근을 보장하려고 노력한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "Two plus three equals five.",
          "ko": "2 더하기 3은 5와 같다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "His hard work finally equaled the record that was set ten years ago.",
          "ko": "그의 노력은 마침내 10년 전에 세워진 기록과 같아졌다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Economists warn that rising productivity does not always equal greater happiness, since well-being depends on many nonmaterial factors.",
          "ko": "경제학자들은 생산성 상승이 항상 더 큰 행복과 같지는 않다고 경고하는데, 행복은 많은 비물질적 요소에 달려 있기 때문이다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "She treats everyone as an equal.",
          "ko": "그녀는 모두를 동등한 사람으로 대한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "In debate club, students learn to argue with their equals in a fair way.",
          "ko": "토론 동아리에서 학생들은 대등한 상대와 공정하게 논쟁하는 법을 배운다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Genuine collaboration flourishes only when scholars regard one another as intellectual equals rather than as rivals competing for recognition.",
          "ko": "진정한 협력은 학자들이 서로를 인정받으려 경쟁하는 경쟁자가 아니라 지적으로 대등한 존재로 여길 때에만 번성한다.",
          "sort_order": 2
        }
      ]
    },
    "380": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "전달하다; 나르다; 운반하다",
          "sort_order": 0
