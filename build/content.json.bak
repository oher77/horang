    "2306": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "추론; 추리; 추정",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Her smile led me to a simple inference about the news.",
          "ko": "그녀의 미소는 그 소식에 대한 간단한 추론으로 나를 이끌었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The detective made an inference from the clues that were left at the scene.",
          "ko": "그 형사는 현장에 남겨진 단서들로부터 추론을 이끌어 냈다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Scientists must distinguish between direct observation and inference, since conclusions drawn from indirect evidence often require careful verification.",
          "ko": "과학자들은 직접 관찰과 추론을 구분해야 하는데, 간접 증거에서 도출된 결론은 흔히 신중한 검증을 요구하기 때문이다.",
          "sort_order": 2
        }
      ]
    },
    "1671": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "이성적인; 합리적인; 논리적인",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "She stayed rational and did not panic during the test.",
          "ko": "그녀는 시험 중에 이성적으로 행동했고 당황하지 않았다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "A rational decision requires that we compare the costs and benefits before we choose.",
          "ko": "합리적인 결정은 선택하기 전에 비용과 이익을 비교할 것을 요구한다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "Economists once assumed that consumers are perfectly rational, yet recent studies reveal that emotions frequently shape our financial choices.",
          "ko": "경제학자들은 한때 소비자가 완벽하게 이성적이라고 가정했지만, 최근 연구들은 감정이 우리의 재정적 선택을 자주 좌우한다는 것을 밝혀낸다.",
          "sort_order": 2
        }
      ]
    },
    "421": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "창조하다; 만들어 내다; 창출하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "She likes to create art with paper and paint.",
          "ko": "그녀는 종이와 물감으로 예술 작품을 만드는 것을 좋아한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The new factory will create hundreds of jobs for people who live nearby.",
          "ko": "그 새 공장은 근처에 사는 사람들을 위해 수백 개의 일자리를 창출할 것이다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Great writers create fictional worlds so convincing that readers momentarily forget the boundary between imagination and reality.",
          "ko": "위대한 작가들은 독자들이 상상과 현실의 경계를 잠시 잊을 만큼 설득력 있는 허구의 세계를 창조한다.",
          "sort_order": 2
        }
      ]
    },
    "1952": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "후원자; 광고주; 보증인",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "후원하다; 지원하다; 주최하다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The sponsor gave money for the school event.",
          "ko": "그 후원자는 학교 행사에 돈을 냈다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The company became the main sponsor of the marathon that thousands of runners joined.",
          "ko": "그 회사는 수천 명의 주자가 참가한 마라톤의 주요 후원자가 되었다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A corporate sponsor often expects measurable returns, so nonprofit groups must clearly show how the donated funds serve public interests.",
          "ko": "기업 후원자는 흔히 측정 가능한 대가를 기대하므로, 비영리 단체는 기부금이 어떻게 공익에 기여하는지 명확히 보여 주어야 한다.",
          "sort_order": 2
        }
      ]
    },
    "1265": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "상인; 무역상",
          "sort_order": 0
        },
        {
          "pos": "a",
          "meaning_ko": "상업의; 무역의",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The merchant sold fruit at the busy market.",
          "ko": "그 상인은 붐비는 시장에서 과일을 팔았다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "A wealthy merchant who traveled far often brought rare goods to the town.",
          "ko": "멀리 여행한 부유한 상인은 종종 진귀한 물건들을 마을로 가져왔다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "During the medieval era, merchants who established trade routes across continents accumulated influence that rivaled that of local rulers.",
          "ko": "중세 시대에 대륙을 가로지르는 무역로를 개척한 상인들은 지역 통치자에 필적하는 영향력을 축적했다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "The merchant ship left the harbor at dawn.",
          "ko": "그 상선은 새벽에 항구를 떠났다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The country built a strong merchant fleet so that it could expand its overseas trade.",
          "ko": "그 나라는 해외 무역을 확대할 수 있도록 강력한 상선단을 건설했다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 3,
          "en": "The prosperity of the merchant class, which financed voyages and lent money to governments, gradually reshaped the political landscape of Europe.",
          "ko": "항해에 자금을 대고 정부에 돈을 빌려준 상인 계급의 번영은 점차 유럽의 정치적 지형을 재편했다.",
          "sort_order": 2
        }
      ]
    },
    "1481": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "인식하다; 인지하다; 감지하다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Dogs can perceive sounds that people cannot hear.",
          "ko": "개는 사람이 들을 수 없는 소리를 감지할 수 있다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "How we perceive a situation often depends on the mood we are in at the time.",
          "ko": "우리가 어떤 상황을 어떻게 인식하는가는 종종 그때 우리가 처한 기분에 달려 있다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "People tend to perceive ambiguous events in ways that confirm their existing beliefs, a tendency psychologists call confirmation bias.",
          "ko": "사람들은 모호한 사건을 자신의 기존 신념을 확인하는 방식으로 인식하는 경향이 있는데, 심리학자들은 이를 확증 편향이라 부른다.",
          "sort_order": 2
        }
      ]
    },
    "1244": {
      "meanings": [
        {
          "pos": "ad",
          "meaning_ko": "아마; 어쩌면",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "ad",
          "level": 1,
          "en": "Maybe we can go to the park later.",
          "ko": "어쩌면 우리 나중에 공원에 갈 수 있어.",
          "sort_order": 0
        },
        {
          "pos": "ad",
          "level": 2,
          "en": "Maybe the meeting was canceled because too few members showed up on time.",
          "ko": "아마 정시에 나타난 회원이 너무 적어서 회의가 취소되었을 것이다.",
          "sort_order": 1
        },
        {
          "pos": "ad",
          "level": 3,
          "en": "Maybe the sudden shift in consumer behavior reflects deeper anxieties that economists have not yet fully measured or explained.",
          "ko": "어쩌면 소비자 행동의 갑작스러운 변화는 경제학자들이 아직 충분히 측정하거나 설명하지 못한 더 깊은 불안을 반영하는 것일 수 있다.",
          "sort_order": 2
        }
      ]
    },
    "1201": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "논리; 논리학; 타당성",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "His answer had no logic at all.",
          "ko": "그의 대답에는 전혀 논리가 없었다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The teacher explained the logic behind the rule so that students could follow it.",
          "ko": "선생님은 학생들이 따라올 수 있도록 그 규칙 뒤에 있는 논리를 설명했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 2,
          "en": "I could not understand the logic of her decision to leave the safe job.",
          "ko": "나는 안정된 직장을 떠나기로 한 그녀의 결정의 논리를 이해할 수 없었다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Although his argument seemed persuasive, closer analysis revealed that its internal logic collapsed under a single contradictory assumption.",
          "ko": "그의 주장은 설득력 있어 보였지만, 더 면밀히 분석하자 그 내부 논리가 하나의 모순된 가정 아래 무너진다는 것이 드러났다.",
          "sort_order": 3
        }
      ]
    },
    "1542": {
      "meanings": [
        {
          "pos": "a",
          "meaning_ko": "인기 있는; 대중적인; 유행하는",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "a",
          "level": 1,
          "en": "This song is very popular with young people.",
          "ko": "이 노래는 젊은 사람들에게 매우 인기가 있다.",
          "sort_order": 0
        },
        {
          "pos": "a",
          "level": 2,
          "en": "The new teacher quickly became popular because she explained difficult ideas in a simple way.",
          "ko": "새 선생님은 어려운 개념을 쉽게 설명해서 금방 인기를 얻었다.",
          "sort_order": 1
        },
        {
          "pos": "a",
          "level": 2,
          "en": "Online shopping has grown popular among students who want to save both time and money.",
          "ko": "온라인 쇼핑은 시간과 돈을 모두 아끼려는 학생들 사이에서 인기를 얻었다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 3,
          "en": "A belief that is widely popular is not necessarily true, since majority opinion can be shaped by emotion rather than careful evidence.",
          "ko": "널리 인기 있는 믿음이 반드시 참인 것은 아닌데, 다수 의견은 신중한 증거보다 감정에 의해 형성될 수 있기 때문이다.",
          "sort_order": 3
        }
      ]
    },
    "1307": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "순간; 잠깐; 때",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Please wait a moment while I find your book.",
          "ko": "제가 당신의 책을 찾는 동안 잠깐 기다려 주세요.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "At that moment, the students realized why their teacher had warned them about the deadline.",
          "ko": "그 순간 학생들은 왜 선생님이 마감일에 대해 경고했는지 깨달았다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Psychologists suggest that living in the present moment can reduce anxiety, since people often suffer more from imagined futures than from present reality.",
          "ko": "심리학자들은 현재의 순간에 사는 것이 불안을 줄일 수 있다고 말하는데, 사람들은 흔히 현재의 현실보다 상상된 미래로 인해 더 고통받기 때문이다.",
          "sort_order": 2
        }
      ]
    },
    "2223": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "기업; 법인; 주식회사",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "My uncle works for a large corporation in the city.",
          "ko": "우리 삼촌은 도시의 큰 기업에서 일하신다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The corporation announced that it would hire more workers to expand its factories.",
          "ko": "그 회사는 공장을 확장하기 위해 더 많은 직원을 고용하겠다고 발표했다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "A multinational corporation must balance the pursuit of profit against its responsibility to the communities and environments it affects.",
          "ko": "다국적 기업은 이윤 추구와 자신이 영향을 미치는 지역사회 및 환경에 대한 책임 사이에서 균형을 맞추어야 한다.",
          "sort_order": 2
        }
      ]
    },
    "1964": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "서다; 서 있다; 견디다; 참다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "태도; 입장; 가판대; 관중석",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "Please stand up when your name is called.",
          "ko": "이름이 불리면 일어서세요.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "She could not stand the noise while she was trying to study for the exam.",
          "ko": "그녀는 시험 공부를 하려는 동안 그 소음을 참을 수 없었다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Great leaders often stand firm on their principles even when public opinion pressures them to compromise their values.",
          "ko": "위대한 지도자들은 여론이 자신의 가치를 타협하도록 압박할 때조차 원칙을 굳건히 지키는 경우가 많다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "We bought some fruit at a small stand.",
          "ko": "우리는 작은 가판대에서 과일을 좀 샀다.",
          "sort_order": 3
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The politician took a clear stand on the issue that many students cared about.",
          "ko": "그 정치인은 많은 학생들이 관심을 갖는 그 문제에 분명한 입장을 취했다.",
          "sort_order": 4
        },
        {
          "pos": "n",
          "level": 3,
          "en": "By refusing to remain silent, the scientist made a courageous stand against widely accepted but flawed assumptions.",
          "ko": "침묵하기를 거부함으로써 그 과학자는 널리 받아들여지지만 결함이 있는 가정에 맞서 용기 있는 입장을 취했다.",
          "sort_order": 5
        }
      ]
    },
    "424": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "기어가다; 살금살금 움직이다; 서서히 나타나다",
          "sort_order": 0
        },
        {
          "pos": "n",
          "meaning_ko": "불쾌한 사람; 서서히 진행되는 변화",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "The cat began to creep toward the little bird.",
          "ko": "그 고양이는 작은 새를 향해 살금살금 다가가기 시작했다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "He tried to creep out of the room quietly so that nobody would notice him.",
          "ko": "그는 아무도 눈치채지 못하도록 조용히 방에서 살금살금 빠져나가려 했다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "A sense of anxiety began to creep into her mind as the deadline approached and the results remained uncertain.",
          "ko": "마감이 다가오고 결과가 여전히 불확실해지자 불안감이 서서히 그녀의 마음속으로 스며들기 시작했다.",
          "sort_order": 2
        },
        {
          "pos": "n",
          "level": 1,
          "en": "Everyone thought the rude man was a real creep.",
          "ko": "모두가 그 무례한 남자를 정말 불쾌한 사람이라고 생각했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The slow creep of prices worried families who had to plan their monthly budget carefully.",
          "ko": "물가의 느린 상승은 매달 예산을 신중히 짜야 하는 가정들을 걱정시켰다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Economists warned that the gradual creep of inflation could erode household savings faster than most consumers expected.",
          "ko": "경제학자들은 물가 상승의 점진적 진행이 대부분의 소비자가 예상한 것보다 더 빠르게 가계 저축을 잠식할 수 있다고 경고했다.",
          "sort_order": 2
        }
      ]
    },
    "995": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "배고픔; 굶주림; 갈망",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "갈망하다; 굶주리다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "After the long walk, I felt a great hunger.",
          "ko": "긴 산책 후에 나는 심한 배고픔을 느꼈다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "Many charities work hard to fight hunger in regions where crops often fail.",
          "ko": "많은 자선단체는 농작물이 자주 실패하는 지역에서 굶주림과 싸우기 위해 열심히 일한다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Beyond physical need, a hunger for recognition often drives people to pursue goals that offer little material reward.",
          "ko": "신체적 필요를 넘어, 인정에 대한 갈망은 종종 사람들이 물질적 보상이 거의 없는 목표를 추구하게 만든다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "The children hunger for a warm meal at night.",
          "ko": "아이들은 밤에 따뜻한 식사를 갈망한다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Students who hunger for knowledge tend to ask questions that surprise their teachers.",
          "ko": "지식을 갈망하는 학생들은 교사를 놀라게 하는 질문을 하는 경향이 있다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "People who have long been overlooked may hunger for approval so intensely that they sacrifice their own values to gain it.",
          "ko": "오랫동안 무시당해 온 사람들은 인정을 너무나 갈망한 나머지 그것을 얻기 위해 자신의 가치관을 희생하기도 한다.",
          "sort_order": 2
        }
      ]
    },
    "777": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "여과기; 필터",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "여과하다; 거르다; 걸러내다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "You should clean the water filter once a week.",
          "ko": "너는 일주일에 한 번 정수 필터를 청소해야 한다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "The camera has a special filter that reduces the bright light from the sun.",
          "ko": "그 카메라에는 태양의 강한 빛을 줄여 주는 특수 필터가 있다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Our brain acts as a filter, selecting only the information that seems relevant while ignoring countless other signals.",
          "ko": "우리의 뇌는 필터처럼 작동하여, 무수한 다른 신호들은 무시하면서 관련 있어 보이는 정보만을 선별한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "This machine filters dirt from the water.",
          "ko": "이 기계는 물에서 오물을 걸러낸다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The app filters out messages that contain harmful words before you read them.",
          "ko": "그 앱은 네가 읽기 전에 해로운 단어가 포함된 메시지를 걸러낸다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Social media algorithms filter the content we see, gradually shaping our opinions in ways we rarely notice.",
          "ko": "소셜 미디어 알고리즘은 우리가 보는 콘텐츠를 걸러내어, 우리가 좀처럼 알아차리지 못하는 방식으로 점차 우리의 견해를 형성한다.",
          "sort_order": 2
        }
      ]
    },
    "1078": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "내부; 실내; 인테리어",
          "sort_order": 0
        },
        {
          "pos": "a",
          "meaning_ko": "내부의; 실내의; 안쪽의",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "The interior of the house was warm and cozy.",
          "ko": "집 안의 내부는 따뜻하고 아늑했다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "When we opened the door, the interior of the museum was much larger than it looked outside.",
          "ko": "문을 열었을 때, 박물관의 내부는 밖에서 보이던 것보다 훨씬 컸다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "The vast interior of the continent remained unexplored for centuries because harsh conditions discouraged travelers from venturing beyond the coast.",
          "ko": "그 대륙의 광활한 내부는 혹독한 환경이 여행자들이 해안 너머로 나아가는 것을 막았기 때문에 수 세기 동안 미탐사 상태로 남아 있었다.",
          "sort_order": 2
        },
        {
          "pos": "a",
          "level": 1,
          "en": "They painted the interior walls white.",
