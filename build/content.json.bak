        {
          "pos": "ad",
          "level": 1,
          "en": "You are dead right about the answer.",
          "ko": "너는 그 답에 대해 완전히 옳다.",
          "sort_order": 0
        },
        {
          "pos": "ad",
          "level": 2,
          "en": "The bus stopped dead in the middle of the road when the engine suddenly failed.",
