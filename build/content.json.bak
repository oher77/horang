    },
    "994": {
      "meanings": [
        {
          "pos": "n",
          "meaning_ko": "유머; 익살; 재미",
          "sort_order": 0
        },
        {
          "pos": "v",
          "meaning_ko": "비위를 맞추다; 기분을 맞춰 주다",
          "sort_order": 1
        }
      ],
      "examples": [
        {
          "pos": "n",
          "level": 1,
          "en": "Her sense of humor makes everyone in class laugh.",
          "ko": "그녀의 유머 감각은 반의 모든 사람을 웃게 만든다.",
          "sort_order": 0
        },
        {
          "pos": "n",
          "level": 2,
          "en": "A speaker who uses humor well can hold the audience's attention throughout a long talk.",
          "ko": "유머를 잘 사용하는 연설자는 긴 강연 내내 청중의 주의를 붙잡을 수 있다.",
          "sort_order": 1
        },
        {
          "pos": "n",
          "level": 3,
          "en": "Psychologists suggest that humor serves as a coping mechanism, allowing people to reframe stressful events in a lighter and more manageable way.",
          "ko": "심리학자들은 유머가 대처 기제로 작용하여 사람들이 스트레스 상황을 더 가볍고 감당할 만한 방식으로 재구성하게 해 준다고 말한다.",
          "sort_order": 2
        },
        {
          "pos": "v",
          "level": 1,
          "en": "She smiled and tried to humor the crying child.",
          "ko": "그녀는 미소를 지으며 우는 아이의 기분을 맞춰 주려 했다.",
          "sort_order": 3
        },
        {
          "pos": "v",
          "level": 2,
          "en": "The teacher chose to humor the student's odd idea instead of dismissing it right away.",
          "ko": "교사는 학생의 이상한 생각을 즉시 묵살하기보다 그 비위를 맞춰 주기로 했다.",
          "sort_order": 4
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Skilled negotiators often humor their opponents' minor demands in order to build trust before pursuing their own critical objectives.",
          "ko": "숙련된 협상가들은 자신의 핵심 목표를 추구하기 전에 신뢰를 쌓기 위해 상대의 사소한 요구를 종종 들어주며 비위를 맞춘다.",
          "sort_order": 5
        }
      ]
    },
    "1109": {
      "meanings": [
