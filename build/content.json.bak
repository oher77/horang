    "1160": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "배우다; 학습하다; 알게 되다",
          "sort_order": 0
        }
      ],
      "examples": [
        {
          "pos": "v",
          "level": 1,
          "en": "I want to learn how to swim this summer.",
          "ko": "나는 이번 여름에 수영하는 법을 배우고 싶다.",
          "sort_order": 0
        },
        {
          "pos": "v",
          "level": 2,
          "en": "Students often learn better when they connect new ideas to what they already know.",
          "ko": "학생들은 새로운 개념을 이미 아는 것과 연결할 때 더 잘 배우는 경우가 많다.",
          "sort_order": 1
        },
        {
          "pos": "v",
          "level": 3,
          "en": "Psychologists argue that people learn most effectively when failure is treated as feedback rather than as a source of lasting shame.",
          "ko": "심리학자들은 실패가 지속적인 수치의 원천이 아니라 피드백으로 여겨질 때 사람들이 가장 효과적으로 배운다고 주장한다.",
          "sort_order": 2
        }
      ]
    },
    "1661": {
      "meanings": [
        {
          "pos": "v",
          "meaning_ko": "올리다; 인상하다; 기르다; (돈을) 모으다",
